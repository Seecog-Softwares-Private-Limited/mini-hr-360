    // =======================================
    // Form submit logic (Create / Edit)
    // =======================================
    async function saveEmployeeFromForm() {
      if (!addEmployeeForm) throw new Error("Employee form not found");

      updateWizardValidity();
      const firstBad = findFirstInvalidStep();
      if (firstBad !== -1) {
        goToStep(firstBad);
        currentStep = firstBad;
        updateWizardButtons();
        validateTab(firstBad, { markInvalid: true });
        updateWizardValidity();
        throw new Error("Please fill all required fields (*) before saving.");
      }

      const formData = new FormData(addEmployeeForm);
      const base = Object.fromEntries(formData.entries());
      delete base.id;

      base.sendCredentialsEmail = "false";
      base.educations = collectEducationRows();
      base.experiences = collectExperienceRows();
      base.documents = collectDocumentRows();

      let url = "/api/v1/employees";
      let method = "POST";

      if (formMode === "edit" && currentEditingId) {
        url = "/api/v1/employees/" + currentEditingId;
        method = "PUT";
      }

      const res = await fetch(url, {
        method,
        headers: { "Content-Type": "application/json" },
        credentials: "include",
        body: JSON.stringify(base),
      });

      if (!res.ok) {
        let err;
        try {
          err = await res.json();
        } catch (e) {
          err = {};
        }
        throw new Error(err.error || err.message || "Failed to save employee");
      }

      return res.json();
    }

    async function sendPortalCredentialsFromForm() {
      const email = addEmployeeForm?.elements?.empEmail?.value?.trim();
      if (!email) {
        alert("Employee email is required to send credentials.");
        return;
      }

      if (!confirm(`Send portal login credentials to ${email}?`)) return;

      const btn = sendPortalCredentialsFormBtn;
      const originalHtml = btn?.innerHTML;
      if (btn) {
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Sending...';
      }
      setSendPortalCredentialsStatus("Saving employee profile...", "muted");

      try {
        let employeeId = currentEditingId;
        if (!employeeId || formMode === "create") {
          const saved = await saveEmployeeFromForm();
          employeeId = saved.id;
          currentEditingId = employeeId;
          formMode = "edit";
          if (employeeIdField) employeeIdField.value = String(employeeId);
        }

        setSendPortalCredentialsStatus("Sending credentials...", "muted");

        const res = await fetch(`/api/v1/employees/${employeeId}/portal-access/send`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "include",
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || "Failed to send credentials");

        if (data.emailSent) {
          const regenNote = data.passwordRegenerated ? " A new temporary password was included." : "";
          setSendPortalCredentialsStatus(`Credentials sent to ${email}.${regenNote}`, "success");
        } else {
          throw new Error(data.emailError || "Credentials could not be emailed. Check SMTP settings.");
        }
      } catch (error) {
        setSendPortalCredentialsStatus(error.message || "Failed to send credentials.", "danger");
        alert(error.message || "Failed to send credentials.");
      } finally {
        if (btn) {
          btn.disabled = false;
          btn.innerHTML = originalHtml || '<i class="fas fa-paper-plane me-2"></i>Send Credentials';
        }
      }
    }

    if (addEmployeeForm) {
      addEmployeeForm.addEventListener("submit", async function (e) {
        e.preventDefault();

        try {
          await saveEmployeeFromForm();
          window.location.reload();
        } catch (error) {
          alert(error.message);
        }
      });
    }

