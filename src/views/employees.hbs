          </button>

          {{!-- Wizard buttons --}}
          <button class="btn btn-primary" type="button" id="wizardNextBtn">
            Next
          </button>
          <button
            class="btn btn-primary d-none"
            type="submit"
            id="wizardSaveBtn"
          >
            Save Employee
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

