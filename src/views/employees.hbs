    async function deleteEmployee(id, name) {
      const label = name ? `"${name}"` : "this employee";
      const confirmed = window.confirm(
        `Delete ${label}? This action cannot be undone.`
      );
      if (!confirmed) return;

      try {
        const res = await fetch("/api/v1/employees/" + id, {
          method: "DELETE",
        });

        if (!res.ok) {
          let err;
          try {
            err = await res.json();
          } catch (e) {
            err = {};
          }
          throw new Error(err.error || "Failed to delete employee");
        }

        window.location.reload();
      } catch (error) {
        alert(error.message);
      }
    }

    async function sendEmployeeCredentials(id, email, name, triggerBtn) {
      if (!email) {
        alert("This employee has no registered email address.");
        return;
      }

      if (!confirm(`Send portal login credentials to ${name} at ${email}?`)) return;

      const originalHtml = triggerBtn?.innerHTML;
      if (triggerBtn) {
        triggerBtn.disabled = true;
        if (triggerBtn.classList.contains("dropdown-item")) {
          triggerBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Sending...';
        } else {
          triggerBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
        }
      }

      try {
        const res = await fetch(`/api/v1/employees/${id}/portal-access/send`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "include",
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || "Failed to send credentials");

        const portalAccess = data.portalAccess;
        const regenNote = data.passwordRegenerated
          ? " A new portal password was generated."
          : "";

        if (data.emailSent) {
          alert(`Credentials emailed to ${email}.${regenNote}`);
        } else {
          const errMsg = data.emailError || "Email could not be sent";
          alert(`${errMsg}.${regenNote} Opening credentials so you can share them manually.`);
          if (portalAccess) {
            showPortalCredentialsModal(
              { id, empName: name, empEmail: email, empId: portalAccess.loginEmployeeCode },
              portalAccess
            );
          }
        }
      } catch (error) {
        alert(error.message);
      } finally {
        if (triggerBtn) {
          triggerBtn.disabled = false;
          if (triggerBtn.classList.contains("dropdown-item")) {
            triggerBtn.innerHTML = '<i class="fas fa-paper-plane me-2 text-info"></i>Send portal credentials';
          } else {
            triggerBtn.innerHTML = originalHtml || '<i class="fas fa-paper-plane"></i>';
          }
        }
      }
    }

    // =======================================
    // Global click delegation for View/Edit/Delete/Send credentials
    // =======================================
    document.addEventListener("click", function (e) {
      const sendBtn = e.target.closest(".send-credentials-btn");
      if (sendBtn) {
        if (sendBtn.disabled) return;
        const id = sendBtn.getAttribute("data-id");
        const email = sendBtn.getAttribute("data-email");
        const name = sendBtn.getAttribute("data-name");
        if (id) sendEmployeeCredentials(id, email, name, sendBtn);
        return;
      }

      const viewBtn = e.target.closest(".view-employee-btn");
      if (viewBtn) {
        const id = viewBtn.getAttribute("data-id");
        if (id) openViewEmployeeModal(id);
        return;
      }

      const editBtn = e.target.closest(".edit-employee-btn");
      if (editBtn) {
        const id = editBtn.getAttribute("data-id");
        if (id) openEditEmployeeModal(id);
        return;
      }

      const deleteBtn = e.target.closest(".delete-employee-btn");
      if (deleteBtn) {
        const id = deleteBtn.getAttribute("data-id");
        const name = deleteBtn.getAttribute("data-name");
        if (id) deleteEmployee(id, name);
        return;
      }

      const completeBtn = e.target.closest(".complete-invited-member-btn");
      if (completeBtn) {
        openCompleteInvitedMemberModal(
          completeBtn.getAttribute("data-name"),
          completeBtn.getAttribute("data-email"),
          completeBtn.getAttribute("data-invited-role")
        );
        return;
      }
    });

    addEmployeeForm?.elements?.empEmail?.addEventListener("input", syncPortalUsernameFromEmail);
    portalPasswordInput?.addEventListener("input", updatePortalPasswordStrength);
    document.getElementById("togglePortalPasswordBtn")?.addEventListener("click", togglePortalPasswordVisibility);
    document.getElementById("copyPortalPasswordBtn")?.addEventListener("click", copyPortalPassword);
    regenPortalPasswordBtn?.addEventListener("click", () => {
      if (portalPasswordInput) {
        portalPasswordInput.value = generateDefaultPortalPassword();
        updatePortalPasswordStrength();
      }
    });

    // --- Lifecycle & offboarding checklist ---
    let editingEmployeeId = null;

    function renderOffboardingChecklist(items, progress) {
      const container = document.getElementById("offboardingChecklistItems");
      const badge = document.getElementById("offboardingProgressBadge");
      if (!container) return;
      if (!items || !items.length) {
        container.innerHTML = '<span class="text-muted">No checklist items.</span>';
        return;
      }
      if (badge && progress) badge.textContent = progress.percent + "%";
      container.innerHTML = items.map((item) => `
        <div class="form-check mb-2">
          <input class="form-check-input offboarding-check-item" type="checkbox"
            data-key="${item.key}" id="chk_${item.key}" ${item.done ? "checked" : ""} />
          <label class="form-check-label" for="chk_${item.key}">
            <strong>${item.label}</strong>
            <span class="text-muted">(${item.department})</span>
          </label>
        </div>
      `).join("");
    }

    function renderLifecycleSummaryPanel(data) {
      const stageLabel = document.getElementById("lifecycleTabStageLabel");
      const recommended = document.getElementById("lifecycleTabRecommended");
      const track = document.getElementById("lifecycleTabStageTrack");
      const timeline = document.getElementById("lifecycleTabTimeline");
      const btnOnboarding = document.getElementById("btnOnboardingWizard");
      const btnExit = document.getElementById("btnExitWizardTab");
      const btnDocs = document.getElementById("btnGenerateDocsTab");
      const btnGenerateDocs = document.getElementById("btnGenerateDocs");

      if (!data?.employee) return;

      const emp = data.employee;
      const stage = emp.lifecycleStage || "prospect";
      if (stageLabel) {
        stageLabel.textContent = `${emp.lifecycleStageLabel || stage} · ${emp.employeeType || "Permanent"}`;
      }
      if (recommended) {
        recommended.textContent = data.recommendedDocument
          ? `Recommended next document: ${data.recommendedDocument.name}`
          : "No specific document recommendation for this stage.";
      }
      if (track && data.stages) {
        track.innerHTML = data.stages.map((s) => {
          const cls = s.current ? "bg-primary" : s.completed ? "bg-success" : "bg-light text-muted";
          return `<span class="badge ${cls} me-1 mb-1">${s.label}</span>`;
        }).join("");
      }
      if (timeline) {
        const events = (data.events || []).slice(0, 5);
        timeline.innerHTML = events.length
          ? events.map((e) => `<div class="border-bottom pb-1 mb-1">${e.action || "event"} · ${e.fromStage || "—"} → ${e.toStage} · ${new Date(e.createdAt).toLocaleString()}</div>`).join("")
          : "No lifecycle events recorded yet.";
      }

      const onboardingStages = ["prospect", "offer", "joining", "active", "confirmed"];
      const exitStages = ["offboarding", "exited"];
      if (btnOnboarding && editingEmployeeId) {
        btnOnboarding.href = `/onboarding-workflow/${editingEmployeeId}`;
        btnOnboarding.classList.toggle("d-none", !onboardingStages.includes(stage));
      }
      if (btnExit && editingEmployeeId) {
        btnExit.href = `/exit-workflow/${editingEmployeeId}`;
        btnExit.classList.toggle("d-none", !exitStages.includes(stage) && stage !== "active" && stage !== "confirmed");
      }
      if (btnDocs && editingEmployeeId) {
        const docQs = data.recommendedDocument?.id ? `?employeeId=${editingEmployeeId}&docTypeId=${data.recommendedDocument.id}` : `?employeeId=${editingEmployeeId}`;
        btnDocs.href = `/documents${docQs}`;
        btnDocs.classList.remove("d-none");
      }
      if (btnGenerateDocs && editingEmployeeId) {
        const docQs = data.recommendedDocument?.id ? `?employeeId=${editingEmployeeId}&docTypeId=${data.recommendedDocument.id}` : `?employeeId=${editingEmployeeId}`;
        btnGenerateDocs.href = `/documents${docQs}`;
      }

      const btnAccept = document.getElementById("btnAcceptOffer");
      const btnConfirm = document.getElementById("btnConfirmEmployment");
      if (btnAccept) btnAccept.classList.toggle("d-none", stage !== "offer");
      if (btnConfirm) btnConfirm.classList.toggle("d-none", stage !== "active");
    }

    async function loadLifecycleForEmployee(employeeId) {
      if (!employeeId) return;
      editingEmployeeId = employeeId;
      const actionBtns = document.getElementById("lifecycleActionBtns");
      if (actionBtns) actionBtns.style.display = "flex";

      try {
        const res = await fetch(`/api/v1/employees/${employeeId}/lifecycle`);
        if (!res.ok) return;
        const data = await res.json();
        renderOffboardingChecklist(data.offboardingChecklist, data.offboardingProgress);
        renderLifecycleSummaryPanel(data);
      } catch (e) {
        console.warn("Lifecycle load failed", e);
      }
    }

    document.getElementById("offboardingChecklistItems")?.addEventListener("change", async (e) => {
      const cb = e.target.closest(".offboarding-check-item");
      if (!cb || !editingEmployeeId) return;
      const items = Array.from(document.querySelectorAll(".offboarding-check-item")).map((el) => ({
        key: el.getAttribute("data-key"),
        done: el.checked,
      }));
      try {
        const res = await fetch(`/api/v1/employees/${editingEmployeeId}/lifecycle/offboarding-checklist`, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ items }),
        });
        if (res.ok) {
          const data = await res.json();
          const badge = document.getElementById("offboardingProgressBadge");
          if (badge && data.progress) badge.textContent = data.progress.percent + "%";
        }
      } catch (err) {
        alert(err.message);
      }
    });

    document.getElementById("btnOpenExitWizard")?.addEventListener("click", (e) => {
      e.preventDefault();
      if (!editingEmployeeId) return;
      window.location.href = `/exit-workflow/${editingEmployeeId}`;
    });

    document.getElementById("btnInitiateExit")?.addEventListener("click", async () => {
      if (!editingEmployeeId) return;
      const lwd = document.querySelector('[name="lastWorkingDay"]')?.value;
      if (!lwd) { alert("Set Last Working Day first."); return; }
      const res = await fetch(`/api/v1/employees/${editingEmployeeId}/lifecycle/exit/initiate`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          resignationDate: document.querySelector('[name="resignationDate"]')?.value,
          lastWorkingDay: lwd,
          noticePeriodDays: document.querySelector('[name="noticePeriodDays"]')?.value,
          exitReason: document.querySelector('[name="exitReason"]')?.value,
          exitType: document.querySelector('[name="exitType"]')?.value,
        }),
      });
      const data = await res.json();
      alert(res.ok ? "Exit initiated — stage: " + data.lifecycleStage : (data.error || "Failed"));
    });

    document.getElementById("btnCompleteExit")?.addEventListener("click", async () => {
      if (!editingEmployeeId) return;
      if (!confirm("Mark employee as exited and inactive?")) return;
      const res = await fetch(`/api/v1/employees/${editingEmployeeId}/lifecycle/exit/complete`, { method: "POST" });
      const data = await res.json();
      alert(res.ok ? "Exit completed." : (data.error || "Failed"));
    });

    document.getElementById("btnSyncPayroll")?.addEventListener("click", async () => {
      if (!editingEmployeeId) return;
      const res = await fetch(`/api/v1/employees/${editingEmployeeId}/lifecycle/sync-payroll`, { method: "POST" });
      const data = await res.json();
      alert(res.ok ? "Payroll synced (" + data.action + ")." : (data.error || "Failed"));
    });

    document.getElementById("btnAcceptOffer")?.addEventListener("click", async () => {
      if (!editingEmployeeId) return;
      const doj = document.querySelector('[name="empDateOfJoining"]')?.value;
      const res = await fetch(`/api/v1/employees/${editingEmployeeId}/lifecycle/offer/accept`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ empDateOfJoining: doj || undefined }),
      });
      const data = await res.json();
      if (res.ok) {
        alert("Offer accepted — stage: " + data.lifecycleStage);
        loadLifecycleForEmployee(editingEmployeeId);
      } else {
        alert(data.error || "Failed");
      }
    });

    document.getElementById("btnConfirmEmployment")?.addEventListener("click", async () => {
      if (!editingEmployeeId) return;
      if (!confirm("Confirm this employee's employment (post-probation)?")) return;
      const res = await fetch(`/api/v1/employees/${editingEmployeeId}/lifecycle/confirm`, { method: "POST" });
      const data = await res.json();
      if (res.ok) {
        alert("Employment confirmed — stage: " + data.lifecycleStage);
        loadLifecycleForEmployee(editingEmployeeId);
      } else {
        alert(data.error || "Failed");
      }
    });

    document.getElementById("btnRunBulkImport")?.addEventListener("click", async () => {
      const managerId = document.getElementById("bulkImportManagerId")?.value;
      const fileInput = document.getElementById("bulkImportFile");
      const resultEl = document.getElementById("bulkImportResult");
      if (!managerId) return alert("Select a default reporting manager.");
      if (!fileInput?.files?.[0]) return alert("Choose a CSV file.");
      const csv = await fileInput.files[0].text();
      const btn = document.getElementById("btnRunBulkImport");
      btn.disabled = true;
      resultEl.innerHTML = '<span class="text-muted">Importing…</span>';
      try {
        const res = await fetch("/api/v1/employees/bulk-import", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ csv, defaultReportingManagerId: managerId }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || "Import failed");
        let html = `<div class="alert alert-success py-2">${data.message}</div>`;
        if (data.errors?.length) {
          html += "<ul class='text-danger'>" + data.errors.map((e) => `<li>Line ${e.line}: ${e.message}</li>`).join("") + "</ul>";
        }
        if (data.skipped?.length) {
          html += "<ul class='text-warning'>" + data.skipped.map((s) => `<li>Line ${s.line}: ${s.reason}</li>`).join("") + "</ul>";
        }
        resultEl.innerHTML = html;
        if (data.created?.length) setTimeout(() => window.location.reload(), 1500);
      } catch (err) {
        resultEl.innerHTML = `<div class="alert alert-danger py-2">${err.message}</div>`;
      } finally {
        btn.disabled = false;
      }
    });
  })();
</script>
