                <div class="col-12">
                  <div class="border rounded p-3 bg-light" id="lifecycleSummaryPanel">
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
                      <div>
                        <div class="text-muted small">Current lifecycle stage</div>
                        <div class="fw-semibold" id="lifecycleTabStageLabel">—</div>
                      </div>
                      <div id="lifecycleTabStageBadges"></div>
                    </div>
                    <div class="small text-muted mb-2" id="lifecycleTabRecommended">Recommended next document: —</div>
