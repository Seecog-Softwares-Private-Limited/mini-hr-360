    // =======================================
    // Form submit logic (Create / Edit)
    // =======================================
    if (addEmployeeForm) {
      addEmployeeForm.addEventListener("submit", async function (e) {
        e.preventDefault();

        if (window.EmployeeEducationWizard?.isFormOpen?.()) {
          goToStep(3);
          currentStep = 3;
          updateWizardButtons();
          validateTab(3, { markInvalid: true });
          updateWizardValidity();
          alert("Please save or cancel the open education entry before saving the employee.");
          return;
        }
        if (window.EmployeeExperienceWizard?.isFormOpen?.()) {
          goToStep(4);
          currentStep = 4;
          updateWizardButtons();
          validateTab(4, { markInvalid: true });
          updateWizardValidity();
          alert("Please save or cancel the open experience entry before saving the employee.");
          return;
        }
        if (window.EmployeeDocumentsWizard?.isFormOpen?.()) {
          goToStep(5);
          currentStep = 5;
          updateWizardButtons();
          validateTab(5, { markInvalid: true });
          updateWizardValidity();
          alert("Please save or cancel the open document entry before saving the employee.");
          return;
        }

        if (!validateReportingManager({ markInvalid: true })) {
          goToStep(1);
          currentStep = 1;
          updateWizardButtons();
          updateWizardValidity();
          alert("Please select a reporting manager before saving the employee.");
          return;
        }

        const formData = new FormData(addEmployeeForm);
        const base = Object.fromEntries(formData.entries());

        // Remove id from base; for edit we use URL param
        delete base.id;

        base.sendCredentialsEmail = sendCredentialsEmailCheckbox?.checked ? "true" : "false";
        base.educations = collectEducationRows();
        base.experiences = collectExperienceRows();
        base.documents = collectDocumentRows();

        let url = "/api/v1/employees";
        let method = "POST";

        if (formMode === "edit" && currentEditingId) {
          url = "/api/v1/employees/" + currentEditingId;
          method = "PUT";
        }

        try {
          const res = await fetch(url, {
            method: method,
            headers: { "Content-Type": "application/json" },
            credentials: "include",
            body: JSON.stringify(base),
          });

          if (!res.ok) {
            let err;
            try {
              err = await res.json();
            } catch (e) {
              err = {};
            }
            throw new Error(err.message || err.error || "Failed to save employee");
          }

          const saved = await res.json();

          if (formMode === "create" && saved.portalAccess) {
            bootstrap.Modal.getInstance(modalEl)?.hide();
            reloadAfterPortalCredentials = true;
            showPortalCredentialsModal(saved, saved.portalAccess);
            return;
          }

          window.location.reload();
        } catch (error) {
          alert(error.message);
        }
      });
    }

