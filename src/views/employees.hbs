                  <button type="button" class="btn btn-sm btn-success d-none" id="btnConfirmEmployment"><i class="fa-solid fa-user-check me-1"></i>Confirm Employment</button>
                  <a href="#" class="btn btn-sm btn-warning" id="btnOpenExitWizard"><i class="fa-solid fa-door-open me-1"></i>Exit Workflow</a>
                  <button type="button" class="btn btn-sm btn-outline-warning" id="btnInitiateExit">Initiate Exit</button>
                  <button type="button" class="btn btn-sm btn-outline-danger" id="btnCompleteExit">Complete Exit</button>
                  <button type="button" class="btn btn-sm btn-outline-primary" id="btnSyncPayroll">Sync Payroll Structure</button>
                  <a href="/documents" class="btn btn-sm btn-primary" id="btnGenerateDocs">Generate Documents</a>
                </div>
                <div class="col-12">
                  <div class="alert alert-light border small mb-0">
                    Use <strong>Documents → Generate</strong> for offer, appointment, increment, and exit letters.
                    Lifecycle stage updates automatically when documents are generated.
                  </div>
                </div>
              </div>
            </div>
          </div>{{!-- end tab-content --}}
        </div>{{!-- end modal-body --}}

        <div class="modal-footer">
