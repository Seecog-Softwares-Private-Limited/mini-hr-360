                <div class="mb-3">
                  <div class="doc-section__title">Upload Document <span class="text-danger">*</span></div>
                  <div class="doc-file-upload" id="docFormFileUpload" role="button" tabindex="0">
                    <input type="file" id="docFormFileInput" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,image/jpeg,image/png" />
                    <div class="text-primary mb-1"><i class="fas fa-cloud-arrow-up fa-lg"></i></div>
                    <p class="mb-0 small text-muted">Drag &amp; drop or click to upload PDF, DOC, JPG, or PNG (max 5 MB)</p>
