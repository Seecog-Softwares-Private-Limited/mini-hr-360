          <!-- Documents Card -->
          <div class="view-emp-section-card view-emp-section-card-full">
            <div class="view-emp-card-header">
              <i class="fas fa-file-alt"></i>
              <h6 class="view-emp-card-title">Documents &amp; KYC</h6>
            </div>
            <div class="view-emp-card-body" id="viewDocumentList"></div>
          </div>
        </div>
      </div>
      <div class="modal-footer view-emp-modal-footer d-flex flex-wrap align-items-center gap-3">
        <div class="d-flex align-items-center gap-2 me-auto" id="viewEmployeeStatusControl">
          <span class="small text-muted">Employee status</span>
          <div class="form-check form-switch mb-0">
            <input class="form-check-input" type="checkbox" id="viewEmployeeActiveToggle" />
            <label class="form-check-label" for="viewEmployeeActiveToggle" id="viewEmployeeActiveToggleLabel">Active</label>
          </div>
        </div>
        <button class="btn btn-outline-secondary d-none" type="button" id="viewDefaultPortalPasswordBtn" title="View default portal password (visible only until employee changes it)">
          <i class="fas fa-eye me-1"></i> View default password
        </button>
        <button class="btn btn-secondary view-emp-close-btn" type="button" data-bs-dismiss="modal">
          Close
        </button>
      </div>
    </div>
  </div>
</div>

{{!-- Employee portal credentials (shown after create / password reset) --}}
<div class="modal fade" id="employeePortalCredentialsModal" tabindex="-1" aria-labelledby="employeePortalCredentialsTitle" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header" style="background: linear-gradient(135deg, #6366f1, #8b5cf6); color: #fff;">
        <h5 class="modal-title" id="employeePortalCredentialsTitle">
          <i class="fas fa-user-lock me-2"></i>Portal sign-in details
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p class="text-muted small mb-3" id="portalCredentialsIntro">
          Share these sign-in details with the employee. They can access the portal using their <strong>email</strong> or <strong>employee code</strong>.
        </p>
        <div id="portalEmailSentBanner" class="alert alert-success d-none py-2 small mb-3">
          <i class="fas fa-envelope-circle-check me-1"></i> Credentials emailed to the employee.
        </div>
        <div id="portalEmailFailedBanner" class="alert alert-warning d-none py-2 small mb-3">
          <i class="fas fa-triangle-exclamation me-1"></i>
          <span id="portalEmailFailedText">Credentials could not be emailed — share these sign-in details manually.</span>
        </div>
        <div id="portalEmailRetryWrap" class="d-none mb-3">
          <button type="button" class="btn btn-sm btn-outline-primary" id="portalRetryEmailBtn">
            <i class="fas fa-paper-plane me-1"></i> Resend credentials
          </button>
        </div>

        <div class="mb-3">
          <label class="form-label small text-muted mb-1">Employee</label>
          <div class="fw-bold" id="portalCredEmployeeName">—</div>
        </div>

        <div class="mb-3">
          <label class="form-label small text-muted mb-1">Portal URL</label>
          <div class="input-group input-group-sm">
            <input type="text" class="form-control font-monospace" id="portalCredUrl" readonly>
            <button class="btn btn-outline-secondary" type="button" data-copy-target="portalCredUrl">Copy</button>
            <a class="btn btn-outline-primary" id="portalCredOpenLink" href="/employee/login" target="_blank" rel="noopener">Open</a>
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label small text-muted mb-1">Login email</label>
          <div class="input-group input-group-sm">
            <input type="text" class="form-control font-monospace" id="portalCredEmail" readonly>
            <button class="btn btn-outline-secondary" type="button" data-copy-target="portalCredEmail">Copy</button>
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label small text-muted mb-1">Employee code (alternate login)</label>
          <div class="input-group input-group-sm">
            <input type="text" class="form-control font-monospace" id="portalCredEmpId" readonly>
            <button class="btn btn-outline-secondary" type="button" data-copy-target="portalCredEmpId">Copy</button>
          </div>
        </div>

        <div class="mb-0">
          <label class="form-label small text-muted mb-1">Password</label>
          <div class="input-group input-group-sm">
            <input type="text" class="form-control font-monospace fw-bold" id="portalCredPassword" readonly>
            <button class="btn btn-outline-secondary" type="button" data-copy-target="portalCredPassword">Copy</button>
          </div>
        </div>

        <div class="alert alert-warning mt-3 mb-0 py-2 small">
          <i class="fas fa-shield-halved me-1"></i> This password is shown once. Ask the employee to change it after first login.
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" id="portalCopyAllBtn">
          <i class="fas fa-copy me-1"></i> Copy all
        </button>
        <button type="button" class="btn btn-primary" data-bs-dismiss="modal" id="portalCredentialsDoneBtn">Done</button>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    // =========================
    // Wizard: steps (6 tabs)
    // =========================
    const steps = [
      "tab-basic",
      "tab-job",
      "tab-comp",
      "tab-education",
      "tab-experience",
      "tab-documents",
    ];

    let currentStep = 0;
    const nextBtn = document.getElementById("wizardNextBtn");
    const saveBtn = document.getElementById("wizardSaveBtn");
    const tabsContainer = document.getElementById("addEmployeeTabs");
    const modalEl = document.getElementById("addEmployeeModal");
    const addEmployeeForm = document.getElementById("addEmployeeForm");
    const employeeIdField = document.getElementById("employeeIdField");
    const addEmployeeModalTitle = document.getElementById("addEmployeeModalTitle");

    let formMode = "create"; // 'create' or 'edit'
    let currentEditingId = null;
    let currentViewEmployeeId = null;
    let reloadAfterPortalCredentials = false;
    let currentPortalEmployeeId = null;
    const sendPortalCredentialsFormBtn = document.getElementById("sendPortalCredentialsFormBtn");
    const sendPortalCredentialsFormStatus = document.getElementById("sendPortalCredentialsFormStatus");
    const portalCredentialsSection = document.getElementById("portalCredentialsSection");
    const viewDefaultPortalPasswordBtn = document.getElementById("viewDefaultPortalPasswordBtn");
    const viewEmployeeActiveToggle = document.getElementById("viewEmployeeActiveToggle");
    const viewEmployeeActiveToggleLabel = document.getElementById("viewEmployeeActiveToggleLabel");
    const viewEmpStatusChip = document.getElementById("viewEmpStatusChip");
    const viewEmpStatusText = document.getElementById("viewEmpStatusText");
    const viewEmpStatusIcon = document.getElementById("viewEmpStatusIcon");
    let isUpdatingEmployeeStatus = false;

    function setSendPortalCredentialsStatus(message, type = "muted") {
      if (!sendPortalCredentialsFormStatus) return;
      sendPortalCredentialsFormStatus.textContent = message || "";
      sendPortalCredentialsFormStatus.className = `small mt-2 text-${type}`;
    }

    function copyInputValue(inputId) {
      const el = document.getElementById(inputId);
      if (!el?.value) return;
      navigator.clipboard.writeText(el.value).then(() => {
        const btn = document.querySelector(`[data-copy-target="${inputId}"]`);
        if (btn) {
          const original = btn.textContent;
          btn.textContent = "Copied!";
          setTimeout(() => { btn.textContent = original; }, 1200);
        }
      }).catch(() => alert("Copy failed — please select and copy manually."));
    }

    function showPortalCredentialsModal(employee, portalAccess) {
      if (!portalAccess) return;

      currentPortalEmployeeId = employee?.id || null;

      document.getElementById("portalCredEmployeeName").textContent =
        employee?.empName || `${employee?.firstName || ""} ${employee?.lastName || ""}`.trim() || "Employee";
      document.getElementById("portalCredUrl").value = portalAccess.portalUrl || `${window.location.origin}/employee/login`;
      document.getElementById("portalCredEmail").value = portalAccess.loginEmail || "";
      document.getElementById("portalCredEmpId").value = portalAccess.loginEmployeeCode || "";
      const visiblePassword = portalAccess.password || portalAccess.hrVisibleDefaultPassword || "";
      document.getElementById("portalCredPassword").value = visiblePassword;

      const openLink = document.getElementById("portalCredOpenLink");
      if (openLink) openLink.href = portalAccess.portalUrl || "/employee/login";

      const sentBanner = document.getElementById("portalEmailSentBanner");
      const failedBanner = document.getElementById("portalEmailFailedBanner");
      const failedText = document.getElementById("portalEmailFailedText");
      const retryWrap = document.getElementById("portalEmailRetryWrap");

      const hasEmailAttemptStatus = typeof portalAccess.emailSent === "boolean";
      if (hasEmailAttemptStatus && portalAccess.emailSent) {
        sentBanner?.classList.remove("d-none");
        failedBanner?.classList.add("d-none");
        retryWrap?.classList.add("d-none");
      } else if (hasEmailAttemptStatus) {
        sentBanner?.classList.add("d-none");
        failedBanner?.classList.remove("d-none");
        if (failedText) {
          failedText.textContent = portalAccess.emailError
            ? `Credentials could not be emailed: ${portalAccess.emailError}`
            : "Credentials could not be emailed — share these sign-in details manually.";
        }
        retryWrap?.classList.toggle("d-none", !currentPortalEmployeeId);
      } else {
        sentBanner?.classList.add("d-none");
        failedBanner?.classList.add("d-none");
        retryWrap?.classList.add("d-none");
      }

      const credModal = bootstrap.Modal.getOrCreateInstance(
        document.getElementById("employeePortalCredentialsModal")
      );
      credModal.show();
    }

    document.getElementById("portalRetryEmailBtn")?.addEventListener("click", async () => {
      if (!currentPortalEmployeeId) return;

      const password = document.getElementById("portalCredPassword")?.value || "";
      const btn = document.getElementById("portalRetryEmailBtn");
      if (btn) {
        btn.disabled = true;
        btn.textContent = "Sending...";
      }

      try {
        const res = await fetch(`/api/v1/employees/${currentPortalEmployeeId}/portal-access/send-email`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ password }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || "Failed to send credentials email");

        const sentBanner = document.getElementById("portalEmailSentBanner");
        const failedBanner = document.getElementById("portalEmailFailedBanner");
        const failedText = document.getElementById("portalEmailFailedText");
        const retryWrap = document.getElementById("portalEmailRetryWrap");

        if (data.emailSent || data.portalAccess?.emailSent) {
          sentBanner?.classList.remove("d-none");
          failedBanner?.classList.add("d-none");
          retryWrap?.classList.add("d-none");
        } else {
          const errMsg = data.emailError || data.portalAccess?.emailError || "Email delivery failed";
          if (failedText) failedText.textContent = `Email could not be sent: ${errMsg}`;
          failedBanner?.classList.remove("d-none");
          sentBanner?.classList.add("d-none");
          retryWrap?.classList.remove("d-none");
        }
      } catch (error) {
        alert(error.message);
      } finally {
        if (btn) {
          btn.disabled = false;
          btn.innerHTML = '<i class="fas fa-paper-plane me-1"></i> Retry send email';
        }
      }
    });

    document.querySelectorAll("[data-copy-target]").forEach((btn) => {
      btn.addEventListener("click", () => copyInputValue(btn.getAttribute("data-copy-target")));
    });

    document.getElementById("portalCopyAllBtn")?.addEventListener("click", () => {
      const text = [
        `Employee Portal: ${document.getElementById("portalCredUrl")?.value || ""}`,
        `Email: ${document.getElementById("portalCredEmail")?.value || ""}`,
        `Employee Code: ${document.getElementById("portalCredEmpId")?.value || ""}`,
        `Password: ${document.getElementById("portalCredPassword")?.value || ""}`,
      ].join("\n");
      navigator.clipboard.writeText(text).then(() => alert("Sign-in details copied to clipboard."))
        .catch(() => alert("Copy failed."));
    });

    document.getElementById("employeePortalCredentialsModal")?.addEventListener("hidden.bs.modal", () => {
      if (reloadAfterPortalCredentials) {
        reloadAfterPortalCredentials = false;
        window.location.reload();
      }
    });

    function updateViewEmployeeStatusUI(emp) {
      const isActive = emp?.isActive !== false;
      if (viewEmployeeActiveToggle) {
        viewEmployeeActiveToggle.checked = isActive;
        viewEmployeeActiveToggle.disabled = false;
      }
      if (viewEmployeeActiveToggleLabel) {
        viewEmployeeActiveToggleLabel.textContent = isActive ? "Active" : "Inactive";
      }
      if (viewEmpStatusText) {
        viewEmpStatusText.textContent = isActive ? "Active" : "Inactive";
      }
      if (viewEmpStatusChip) {
        viewEmpStatusChip.style.background = isActive ? "rgba(34,197,94,0.15)" : "rgba(239,68,68,0.15)";
        viewEmpStatusChip.style.color = isActive ? "#166534" : "#991b1b";
      }
      if (viewEmpStatusIcon) {
        viewEmpStatusIcon.style.color = isActive ? "#22c55e" : "#ef4444";
      }
    }

    viewEmployeeActiveToggle?.addEventListener("change", async function () {
      if (!currentViewEmployeeId || isUpdatingEmployeeStatus) return;

      const nextActive = viewEmployeeActiveToggle.checked;
      const previousActive = !nextActive;

      if (!nextActive) {
        const confirmed = confirm(
          "Mark this employee as inactive? They will not be able to sign in to the employee portal."
        );
        if (!confirmed) {
          viewEmployeeActiveToggle.checked = previousActive;
          return;
        }
      }

      isUpdatingEmployeeStatus = true;
      viewEmployeeActiveToggle.disabled = true;

      try {
        const res = await fetch(`/api/v1/employees/${currentViewEmployeeId}/status`, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ isActive: nextActive }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || "Failed to update employee status");

        updateViewEmployeeStatusUI(data);
        const profContainer = document.getElementById("viewProfessionalDetails");
        if (profContainer) {
          const rows = profContainer.querySelectorAll("dt");
          rows.forEach((dt) => {
            if (dt.textContent.trim() === "Account Status") {
              const dd = dt.nextElementSibling;
              if (dd) dd.textContent = nextActive ? "Active" : "Inactive";
            }
          });
        }
      } catch (error) {
        viewEmployeeActiveToggle.checked = previousActive;
        updateViewEmployeeStatusUI({ isActive: previousActive });
        alert(error.message || "Failed to update employee status");
      } finally {
        isUpdatingEmployeeStatus = false;
        if (viewEmployeeActiveToggle) viewEmployeeActiveToggle.disabled = false;
      }
    });

    viewDefaultPortalPasswordBtn?.addEventListener("click", async () => {
      if (!currentViewEmployeeId) return;

      try {
        const emp = await fetchEmployee(currentViewEmployeeId);
        if (!emp?.portalAccess?.hrVisibleDefaultPassword) {
          alert("Default password is no longer visible. The employee may have changed it.");
          return;
        }
        showPortalCredentialsModal(emp, emp.portalAccess);
      } catch (error) {
        alert(error.message || "Failed to load default portal password");
      }
    });

    function updateWizardButtons() {
      if (!nextBtn || !saveBtn) return;

      if (currentStep === steps.length - 1) {
        nextBtn.classList.add("d-none");
        saveBtn.classList.remove("d-none");
      } else {
        nextBtn.classList.remove("d-none");
        saveBtn.classList.add("d-none");
      }

      // Also enforce required-field validation state
      updateWizardValidity();
    }

    // =======================================
    // Required-field validation (based on red asterisk)
    // Wherever a label contains a red "*" marker, the associated control becomes required.
    // "Next" is disabled until required fields in the current tab are filled.
    // "Save" is disabled until required fields in ALL tabs are filled.
    // =======================================

    function isElementVisible(el) {
      if (!el) return false;
      if (el.type === "hidden") return false;
      if (el.disabled) return false;
      // if inside collapsed/hidden tab-pane, offsetParent may be null
      const style = window.getComputedStyle(el);
      if (style.display === "none" || style.visibility === "hidden") return false;
      // If any ancestor is display:none, getClientRects() will be empty
      if (el.getClientRects().length === 0) return false;
      return true;
    }

    function controlHasValue(el) {
      if (!el) return false;
      if (el.type === "checkbox") return el.checked === true;
      if (el.type === "radio") {
        const name = el.name;
        if (!name) return el.checked === true;
        return !!document.querySelector(`input[type="radio"][name="${CSS.escape(name)}"]:checked`);
      }
      if (el.type === "file") return (el.files && el.files.length > 0) || false;
      return String(el.value || "").trim() !== "";
    }

    function markAsteriskRequired(root) {
      if (!root) return;
      // Look for labels that contain a red asterisk marker
      root.querySelectorAll("label").forEach((label) => {
        const hasStar = !!label.querySelector(".text-danger");
        if (!hasStar) return;

        // Find the closest control in the same field container
        const fieldWrap = label.closest(".col, .col-12, .col-md-12, .col-md-6, .col-md-4, .col-md-3, .col-lg-6, .col-lg-4, .mb-3, .row") || label.parentElement;
        if (!fieldWrap) return;

        const control = fieldWrap.querySelector("input, select, textarea");
        if (!control) return;

        // Mark as required (idempotent)
        control.required = true;
        control.dataset.requiredByAsterisk = "true";
      });
    }

    function getTabPaneByStep(stepIdx) {
      const id = steps[stepIdx];
      return id ? document.getElementById(id) : null;
    }

    function validateTab(stepIdx, { markInvalid = false } = {}) {
      const pane = getTabPaneByStep(stepIdx);
      if (!pane) return true;

      // Gather required controls (native required OR asterisk-derived)
      const requiredControls = Array.from(
        pane.querySelectorAll("input[required], select[required], textarea[required], [data-required-by-asterisk='true']")
      ).filter((el) => isElementVisible(el));

      let ok = true;
      requiredControls.forEach((el) => {
        const filled = controlHasValue(el);
        if (!filled) ok = false;
        if (markInvalid) {
          el.classList.toggle("is-invalid", !filled);
        }
      });

      return ok;
    }

    function findFirstInvalidStep() {
      for (let i = 0; i < steps.length; i++) {
        if (!validateTab(i)) return i;
      }
      return -1;
    }

    function updateWizardValidity() {
      if (!nextBtn || !saveBtn) return;
      // Ensure asterisk-required mapping exists before validating
      if (modalEl) markAsteriskRequired(modalEl);

      const currentOk = validateTab(currentStep);
      const allOk = findFirstInvalidStep() === -1;

      // Next: current tab only
      nextBtn.disabled = !currentOk;
      // Save: all tabs
      saveBtn.disabled = !allOk;
    }

    function goToStep(index) {
      if (index < 0 || index >= steps.length) return;

      const targetId = steps[index];
      const trigger = document.querySelector(
        '[data-bs-target="#' + targetId + '"]'
      );

      if (trigger && window.bootstrap) {
        const tab = new bootstrap.Tab(trigger);
        tab.show();
      }
    }

    if (nextBtn) {
      nextBtn.addEventListener("click", function () {
        // Block moving forward if required fields (with red asterisk) aren't filled
        const ok = validateTab(currentStep, { markInvalid: true });
        updateWizardValidity();
        if (!ok) return;

        if (currentStep < steps.length - 1) {
          currentStep += 1;
          goToStep(currentStep);
          updateWizardButtons();
        }
      });
    }

    if (tabsContainer) {
      tabsContainer.addEventListener("shown.bs.tab", function (event) {
        const target = event.target.getAttribute("data-bs-target");
        if (!target) return;

        const id = target.replace("#", "");
        const idx = steps.indexOf(id);

        if (idx !== -1) {
          currentStep = idx;
          updateWizardButtons();
          updateWizardValidity();
        }
      });
    }

    if (modalEl) {
      modalEl.addEventListener("shown.bs.modal", function () {
        currentStep = 0;
        goToStep(currentStep);
        // map required fields and set initial button states
        markAsteriskRequired(modalEl);
        updateWizardButtons();
        updateWizardValidity();
      });

      // Live validation while user edits
      modalEl.addEventListener("input", function (e) {
        const t = e.target;
        if (t && (t.matches("input, select, textarea"))) {
          // remove invalid state as user edits
          if (t.classList.contains("is-invalid") && controlHasValue(t)) {
            t.classList.remove("is-invalid");
          }
          updateWizardValidity();
        }
      });
      modalEl.addEventListener("change", function () {
        updateWizardValidity();
      });
    }

    // =======================================
    // "Permanent same as present" helper
    // =======================================
    const sameAsPresentCheckbox = document.getElementById("sameAsPresent");

    if (sameAsPresentCheckbox) {
      sameAsPresentCheckbox.addEventListener("change", function () {
        if (!this.checked) return;

        const copyField = (from, to) => {
          const f = document.querySelector('[name="' + from + '"]');
          const t = document.querySelector('[name="' + to + '"]');
          if (f && t) t.value = f.value;
        };

        copyField("presentAddressLine1", "permanentAddressLine1");
        copyField("presentAddressLine2", "permanentAddressLine2");
        copyField("presentCity", "permanentCity");
        copyField("presentState", "permanentState");
        copyField("presentZip", "permanentZip");
        copyField("presentCountry", "permanentCountry");
      });
    }

    // =======================================
    // Dynamic rows: Education, Experience, Documents
    // =======================================
    const educationContainer = document.getElementById("educationRows");
    const experienceContainer = document.getElementById("experienceRows");
    const documentContainer = document.getElementById("documentRows");

    const addEducationRowBtn = document.getElementById("addEducationRowBtn");
    const addExperienceRowBtn = document.getElementById("addExperienceRowBtn");
    const addDocumentRowBtn = document.getElementById("addDocumentRowBtn");

    function clearInputsInRow(row) {
      row.querySelectorAll("input, select, textarea").forEach((el) => {
        if (el.type === "checkbox") {
          el.checked = false;
        } else {
          el.value = "";
        }
      });
    }

    function cloneRow(container, rowSelector) {
      const firstRow = container.querySelector(rowSelector);
      if (!firstRow) return;
      const clone = firstRow.cloneNode(true);
      clearInputsInRow(clone);
      container.appendChild(clone);
    }

    function resetDynamicSection(container, rowSelector) {
      if (!container) return;

      const rows = container.querySelectorAll(rowSelector);
      rows.forEach((row, idx) => {
        if (idx === 0) {
          clearInputsInRow(row);
        } else {
          row.remove();
        }
      });
    }

    // Education dynamic
    if (addEducationRowBtn && educationContainer) {
      addEducationRowBtn.addEventListener("click", function () {
        cloneRow(educationContainer, ".education-row");
      });

      educationContainer.addEventListener("click", function (e) {
        const removeBtn = e.target.closest(".remove-education-row-btn");
        if (removeBtn) {
          const row = e.target.closest(".education-row");
          if (
            educationContainer.querySelectorAll(".education-row").length > 1 &&
            row
          ) {
            row.remove();
          }
        }
      });
    }

    // Experience dynamic
    if (addExperienceRowBtn && experienceContainer) {
      addExperienceRowBtn.addEventListener("click", function () {
        cloneRow(experienceContainer, ".experience-row");
      });

      experienceContainer.addEventListener("click", function (e) {
        const removeBtn = e.target.closest(".remove-experience-row-btn");
        if (removeBtn) {
          const row = e.target.closest(".experience-row");
          if (
            experienceContainer.querySelectorAll(".experience-row").length > 1 &&
            row
          ) {
            row.remove();
          }
        }
      });
    }

    // Document dynamic
    if (addDocumentRowBtn && documentContainer) {
      addDocumentRowBtn.addEventListener("click", function () {
        cloneRow(documentContainer, ".document-row");
      });

      documentContainer.addEventListener("click", function (e) {
        const removeBtn = e.target.closest(".remove-document-row-btn");
        if (removeBtn) {
          const row = e.target.closest(".document-row");
          if (documentContainer.querySelectorAll(".document-row").length > 1 && row) {
            row.remove();
          }
        }
      });
    }

    function collectEducationRows() {
      const rows = [];

      document.querySelectorAll(".education-row").forEach((row) => {
        const obj = {
          level: row.querySelector(".edu_level")?.value || "",
          degree: row.querySelector(".edu_degree")?.value || "",
          specialization: row.querySelector(".edu_specialization")?.value || "",
          institutionName:
            row.querySelector(".edu_institutionName")?.value || "",
          board: row.querySelector(".edu_board")?.value || "",
          startYear: row.querySelector(".edu_startYear")?.value || "",
          endYear: row.querySelector(".edu_endYear")?.value || "",
          yearOfPassing:
            row.querySelector(".edu_yearOfPassing")?.value || "",
          percentageOrCgpa:
            row.querySelector(".edu_percentageOrCgpa")?.value || "",
