            docContainer.appendChild(list);
          }
        }

        const viewModalEl = document.getElementById("viewEmployeeModal");
        const viewModal =
          bootstrap.Modal.getOrCreateInstance(viewModalEl);
        viewModal.show();
      } catch (error) {
        alert(error.message);
      }
    }

