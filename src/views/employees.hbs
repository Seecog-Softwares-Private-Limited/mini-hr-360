  </div>
</div>

<script src="/assets/js/employee-education-wizard.js"></script>
<script src="/assets/js/employee-experience-wizard.js"></script>
<script src="/assets/js/employee-documents-wizard.js"></script>
<script>
  (function () {
    // =========================
    // Wizard: steps (6 tabs)
    // =========================
    const steps = [
      "tab-basic",
      "tab-job",
      "tab-comp",
      "tab-education",
      "tab-experience",
      "tab-documents",
      "tab-lifecycle",
    ];

    let currentStep = 0;
    const nextBtn = document.getElementById("wizardNextBtn");
    const saveBtn = document.getElementById("wizardSaveBtn");
    const tabsContainer = document.getElementById("addEmployeeTabs");
    const modalEl = document.getElementById("addEmployeeModal");
    const addEmployeeForm = document.getElementById("addEmployeeForm");
    const employeeIdField = document.getElementById("employeeIdField");
    const addEmployeeModalTitle = document.getElementById("addEmployeeModalTitle");

    let formMode = "create"; // 'create' or 'edit'
    let currentEditingId = null;
    let currentViewEmployeeId = null;
    let reloadAfterPortalCredentials = false;
    let currentPortalEmployeeId = null;
    const portalUsernamePreview = document.getElementById("portalUsernamePreview");
    const portalPasswordInput = document.getElementById("portalPasswordInput");
    const regenPortalPasswordBtn = document.getElementById("regenPortalPasswordBtn");
    const sendCredentialsEmailCheckbox = document.getElementById("sendCredentialsEmailCheckbox");
    const portalCredentialsSection = document.getElementById("portalCredentialsSection");
    const viewDefaultPortalPasswordBtn = document.getElementById("viewDefaultPortalPasswordBtn");
    const viewEmployeeActiveToggle = document.getElementById("viewEmployeeActiveToggle");
    const viewEmployeeActiveToggleLabel = document.getElementById("viewEmployeeActiveToggleLabel");
    const viewEmpStatusChip = document.getElementById("viewEmpStatusChip");
    const viewEmpStatusText = document.getElementById("viewEmpStatusText");
    const viewEmpStatusIcon = document.getElementById("viewEmpStatusIcon");
    let isUpdatingEmployeeStatus = false;

    function generateDefaultPortalPassword() {
      const upper = "ABCDEFGHJKLMNPQRSTUVWXYZ";
      const lower = "abcdefghijkmnpqrstuvwxyz";
      const digits = "23456789";
      const special = "!@#$%&*";
      const all = upper + lower + digits + special;
      const pick = (chars) => chars.charAt(Math.floor(Math.random() * chars.length));
      let out = pick(upper) + pick(lower) + pick(digits) + pick(special);
      for (let i = out.length; i < 14; i += 1) {
        out += pick(all);
      }
      return out.split("").sort(() => Math.random() - 0.5).join("");
    }

    function scorePortalPassword(password) {
      const value = String(password || "");
      if (!value) return { score: 0, label: "—", color: "#e2e8f0", width: "0%" };
      let score = 0;
      if (value.length >= 8) score += 1;
      if (value.length >= 12) score += 1;
      if (/[a-z]/.test(value) && /[A-Z]/.test(value)) score += 1;
      if (/\d/.test(value)) score += 1;
      if (/[^A-Za-z0-9]/.test(value)) score += 1;
      if (score <= 2) return { score, label: "Weak", color: "#ef4444", width: "33%" };
      if (score === 3 || score === 4) return { score, label: "Good", color: "#f59e0b", width: "66%" };
      return { score, label: "Strong", color: "#10b981", width: "100%" };
    }

    function updatePortalPasswordStrength() {
      const fill = document.getElementById("portalPasswordStrengthFill");
      const label = document.getElementById("portalPasswordStrengthLabel");
      if (!portalPasswordInput || !fill || !label) return;
      const result = scorePortalPassword(portalPasswordInput.value);
      fill.style.width = result.width;
      fill.style.background = result.color;
      label.textContent = `Password strength: ${result.label}`;
    }

    function togglePortalPasswordVisibility() {
      if (!portalPasswordInput) return;
      const btn = document.getElementById("togglePortalPasswordBtn");
      const icon = btn?.querySelector("i");
      const isHidden = portalPasswordInput.type === "password";
      portalPasswordInput.type = isHidden ? "text" : "password";
      if (icon) {
        icon.className = isHidden ? "fas fa-eye-slash" : "fas fa-eye";
      }
    }

    function copyPortalPassword() {
      if (!portalPasswordInput?.value) return;
      navigator.clipboard.writeText(portalPasswordInput.value).then(() => {
        const btn = document.getElementById("copyPortalPasswordBtn");
        if (btn) {
          const original = btn.innerHTML;
          btn.innerHTML = '<i class="fas fa-check"></i>';
          setTimeout(() => { btn.innerHTML = original; }, 1200);
        }
      }).catch(() => alert("Copy failed — please copy manually."));
    }

    function syncPortalUsernameFromEmail() {
      const email = addEmployeeForm?.elements?.empEmail?.value || "";
      if (portalUsernamePreview) portalUsernamePreview.value = email;
    }

    function setPortalCredentialsMode(isCreateMode) {
      if (!portalCredentialsSection) return;
      portalCredentialsSection.style.display = isCreateMode ? "" : "none";
      if (isCreateMode) {
        if (portalPasswordInput && !portalPasswordInput.value) {
          portalPasswordInput.value = generateDefaultPortalPassword();
        }
        if (sendCredentialsEmailCheckbox) sendCredentialsEmailCheckbox.checked = true;
        updatePortalPasswordStrength();
      }
    }

    function copyInputValue(inputId) {
      const el = document.getElementById(inputId);
      if (!el?.value) return;
      navigator.clipboard.writeText(el.value).then(() => {
        const btn = document.querySelector(`[data-copy-target="${inputId}"]`);
        if (btn) {
          const original = btn.textContent;
          btn.textContent = "Copied!";
          setTimeout(() => { btn.textContent = original; }, 1200);
        }
      }).catch(() => alert("Copy failed — please select and copy manually."));
    }

    function showPortalCredentialsModal(employee, portalAccess) {
      if (!portalAccess) return;

      currentPortalEmployeeId = employee?.id || null;

      document.getElementById("portalCredEmployeeName").textContent =
        employee?.empName || `${employee?.firstName || ""} ${employee?.lastName || ""}`.trim() || "Employee";
      document.getElementById("portalCredUrl").value = portalAccess.portalUrl || `${window.location.origin}/employee/login`;
      document.getElementById("portalCredEmail").value = portalAccess.loginEmail || "";
      document.getElementById("portalCredEmpId").value = portalAccess.loginEmployeeCode || "";
      const visiblePassword = portalAccess.password || portalAccess.hrVisibleDefaultPassword || "";
      document.getElementById("portalCredPassword").value = visiblePassword;

      const openLink = document.getElementById("portalCredOpenLink");
      if (openLink) openLink.href = portalAccess.portalUrl || "/employee/login";

      const sentBanner = document.getElementById("portalEmailSentBanner");
      const failedBanner = document.getElementById("portalEmailFailedBanner");
      const failedText = document.getElementById("portalEmailFailedText");
      const retryWrap = document.getElementById("portalEmailRetryWrap");

      const hasEmailAttemptStatus = typeof portalAccess.emailSent === "boolean";
      if (hasEmailAttemptStatus && portalAccess.emailSent) {
        sentBanner?.classList.remove("d-none");
        failedBanner?.classList.add("d-none");
        retryWrap?.classList.add("d-none");
      } else if (hasEmailAttemptStatus) {
        sentBanner?.classList.add("d-none");
        failedBanner?.classList.remove("d-none");
        if (failedText) {
          failedText.textContent = portalAccess.emailError
            ? `Email could not be sent: ${portalAccess.emailError}`
            : "Email could not be sent — copy and share these credentials manually.";
        }
        retryWrap?.classList.toggle("d-none", !currentPortalEmployeeId);
      } else {
        sentBanner?.classList.add("d-none");
        failedBanner?.classList.add("d-none");
        retryWrap?.classList.add("d-none");
      }

      const credModal = bootstrap.Modal.getOrCreateInstance(
        document.getElementById("employeePortalCredentialsModal")
      );
      credModal.show();
    }

    document.getElementById("portalRetryEmailBtn")?.addEventListener("click", async () => {
      if (!currentPortalEmployeeId) return;

      const password = document.getElementById("portalCredPassword")?.value || "";
      const btn = document.getElementById("portalRetryEmailBtn");
      if (btn) {
        btn.disabled = true;
        btn.textContent = "Sending...";
      }

      try {
        const res = await fetch(`/api/v1/employees/${currentPortalEmployeeId}/portal-access/send-email`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ password }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || "Failed to send credentials email");

        const sentBanner = document.getElementById("portalEmailSentBanner");
        const failedBanner = document.getElementById("portalEmailFailedBanner");
        const failedText = document.getElementById("portalEmailFailedText");
        const retryWrap = document.getElementById("portalEmailRetryWrap");

        if (data.emailSent || data.portalAccess?.emailSent) {
          sentBanner?.classList.remove("d-none");
          failedBanner?.classList.add("d-none");
          retryWrap?.classList.add("d-none");
        } else {
          const errMsg = data.emailError || data.portalAccess?.emailError || "Email delivery failed";
          if (failedText) failedText.textContent = `Email could not be sent: ${errMsg}`;
          failedBanner?.classList.remove("d-none");
          sentBanner?.classList.add("d-none");
          retryWrap?.classList.remove("d-none");
        }
      } catch (error) {
        alert(error.message);
      } finally {
        if (btn) {
          btn.disabled = false;
          btn.innerHTML = '<i class="fas fa-paper-plane me-1"></i> Retry send email';
        }
      }
    });

    document.querySelectorAll("[data-copy-target]").forEach((btn) => {
      btn.addEventListener("click", () => copyInputValue(btn.getAttribute("data-copy-target")));
    });

    document.getElementById("portalCopyAllBtn")?.addEventListener("click", () => {
      const text = [
        `Employee Portal: ${document.getElementById("portalCredUrl")?.value || ""}`,
        `Email: ${document.getElementById("portalCredEmail")?.value || ""}`,
        `Employee Code: ${document.getElementById("portalCredEmpId")?.value || ""}`,
        `Password: ${document.getElementById("portalCredPassword")?.value || ""}`,
      ].join("\n");
      navigator.clipboard.writeText(text).then(() => alert("All credentials copied to clipboard."))
        .catch(() => alert("Copy failed."));
    });

    document.getElementById("employeePortalCredentialsModal")?.addEventListener("hidden.bs.modal", () => {
      if (reloadAfterPortalCredentials) {
        reloadAfterPortalCredentials = false;
        window.location.reload();
      }
    });

    function updateViewEmployeeStatusUI(emp) {
      const isActive = emp?.isActive !== false;
      if (viewEmployeeActiveToggle) {
        viewEmployeeActiveToggle.checked = isActive;
        viewEmployeeActiveToggle.disabled = false;
      }
      if (viewEmployeeActiveToggleLabel) {
        viewEmployeeActiveToggleLabel.textContent = isActive ? "Active" : "Inactive";
      }
      if (viewEmpStatusText) {
        viewEmpStatusText.textContent = isActive ? "Active" : "Inactive";
      }
      if (viewEmpStatusChip) {
        viewEmpStatusChip.style.background = isActive ? "rgba(34,197,94,0.15)" : "rgba(239,68,68,0.15)";
        viewEmpStatusChip.style.color = isActive ? "#166534" : "#991b1b";
      }
      if (viewEmpStatusIcon) {
        viewEmpStatusIcon.style.color = isActive ? "#22c55e" : "#ef4444";
      }
    }

    viewEmployeeActiveToggle?.addEventListener("change", async function () {
      if (!currentViewEmployeeId || isUpdatingEmployeeStatus) return;

      const nextActive = viewEmployeeActiveToggle.checked;
      const previousActive = !nextActive;

      if (!nextActive) {
        const confirmed = confirm(
          "Mark this employee as inactive? They will not be able to sign in to the employee portal."
        );
        if (!confirmed) {
          viewEmployeeActiveToggle.checked = previousActive;
          return;
        }
      }

      isUpdatingEmployeeStatus = true;
      viewEmployeeActiveToggle.disabled = true;

      try {
        const res = await fetch(`/api/v1/employees/${currentViewEmployeeId}/status`, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ isActive: nextActive }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || "Failed to update employee status");

        updateViewEmployeeStatusUI(data);
        const profContainer = document.getElementById("viewProfessionalDetails");
        if (profContainer) {
          const rows = profContainer.querySelectorAll("dt");
          rows.forEach((dt) => {
            if (dt.textContent.trim() === "Account Status") {
              const dd = dt.nextElementSibling;
              if (dd) dd.textContent = nextActive ? "Active" : "Inactive";
            }
          });
        }
      } catch (error) {
        viewEmployeeActiveToggle.checked = previousActive;
        updateViewEmployeeStatusUI({ isActive: previousActive });
        alert(error.message || "Failed to update employee status");
      } finally {
        isUpdatingEmployeeStatus = false;
        if (viewEmployeeActiveToggle) viewEmployeeActiveToggle.disabled = false;
      }
    });

    viewDefaultPortalPasswordBtn?.addEventListener("click", async () => {
      if (!currentViewEmployeeId) return;

      try {
        const emp = await fetchEmployee(currentViewEmployeeId);
        if (!emp?.portalAccess?.hrVisibleDefaultPassword) {
          alert("Default password is no longer visible. The employee may have changed it.");
          return;
        }
        showPortalCredentialsModal(emp, emp.portalAccess);
      } catch (error) {
        alert(error.message || "Failed to load default portal password");
      }
    });

    function updateWizardButtons() {
      if (!nextBtn || !saveBtn) return;

      if (currentStep === steps.length - 1) {
        nextBtn.classList.add("d-none");
        saveBtn.classList.remove("d-none");
      } else {
        nextBtn.classList.remove("d-none");
        saveBtn.classList.add("d-none");
      }

      // Also enforce required-field validation state
      updateWizardValidity();
    }

    // =======================================
    // Red asterisks are visual guidance only — they do not block save or next.
    // =======================================

    function clearNativeRequiredConstraints(root) {
      if (!root) return;
      root.querySelectorAll("input[required], select[required], textarea[required]").forEach((el) => {
        el.required = false;
        el.removeAttribute("required");
      });
    }

    function markAsteriskFields(root) {
      if (!root) return;
      root.querySelectorAll("label").forEach((label) => {
        const hasStar = !!label.querySelector(".text-danger");
        if (!hasStar) return;

        const fieldWrap = label.closest(".col, .col-12, .col-md-12, .col-md-6, .col-md-4, .col-md-3, .col-lg-6, .col-lg-4, .mb-3, .row") || label.parentElement;
        if (!fieldWrap) return;

        const control = fieldWrap.querySelector("input, select, textarea");
        if (!control) return;

        control.dataset.asteriskField = "true";
        control.required = false;
        control.removeAttribute("required");
      });
    }

    function getTabPaneByStep(stepIdx) {
      const id = steps[stepIdx];
      return id ? document.getElementById(id) : null;
    }

    function getReportingManagerSelect() {
      return document.getElementById("reportingManagerId");
    }

    function refreshReportingManagerOptions(excludeEmployeeId) {
      const select = getReportingManagerSelect();
      if (!select) return;
      const current = select.value;
      Array.from(select.options).forEach((opt) => {
        if (!opt.value) return;
        const hide = excludeEmployeeId && Number(opt.value) === Number(excludeEmployeeId);
        opt.hidden = hide;
        opt.disabled = hide;
      });
      if (excludeEmployeeId && Number(current) === Number(excludeEmployeeId)) {
        select.value = "";
      }
    }

    function validateReportingManager({ markInvalid = false } = {}) {
      const select = getReportingManagerSelect();
      const value = String(select?.value || "").trim();
      const ok = value !== "" && Number(value) > 0;
      if (markInvalid && select) {
        select.classList.toggle("is-invalid", !ok);
      }
      return ok;
    }

    function validateTab(stepIdx, { markInvalid = false } = {}) {
      if (stepIdx === 3 && window.EmployeeEducationWizard) {
        return window.EmployeeEducationWizard.isTabValid({ markInvalid });
      }
      if (stepIdx === 4 && window.EmployeeExperienceWizard) {
        return window.EmployeeExperienceWizard.isTabValid({ markInvalid });
      }
      if (stepIdx === 5 && window.EmployeeDocumentsWizard) {
        return window.EmployeeDocumentsWizard.isTabValid({ markInvalid });
      }
      if (stepIdx === 1) {
        return validateReportingManager({ markInvalid });
      }
      return true;
    }

    function findFirstInvalidStep() {
      for (let i = 0; i < steps.length; i++) {
        if (!validateTab(i)) return i;
      }
      return -1;
    }

    function controlHasValue(el) {
      if (!el) return false;
      if (el.type === "checkbox") return el.checked === true;
      return String(el.value || "").trim() !== "";
    }

    function updateWizardValidity() {
      if (!nextBtn || !saveBtn) return;
      if (modalEl) {
        clearNativeRequiredConstraints(modalEl);
        markAsteriskFields(modalEl);
      }

      const currentOk = validateTab(currentStep);

      nextBtn.disabled = !currentOk;
      saveBtn.disabled = false;
    }

    function goToStep(index) {
      if (index < 0 || index >= steps.length) return;

      const targetId = steps[index];
      const trigger = document.querySelector(
        '[data-bs-target="#' + targetId + '"]'
      );

      if (trigger && window.bootstrap) {
        const tab = new bootstrap.Tab(trigger);
        tab.show();
      }
    }

    if (nextBtn) {
      nextBtn.addEventListener("click", function () {
        if (currentStep === 3 && window.EmployeeEducationWizard?.isFormOpen?.()) {
          validateTab(currentStep, { markInvalid: true });
          updateWizardValidity();
          alert("Please save or cancel the open education entry before continuing.");
          return;
        }
        if (currentStep === 4 && window.EmployeeExperienceWizard?.isFormOpen?.()) {
          validateTab(currentStep, { markInvalid: true });
          updateWizardValidity();
          alert("Please save or cancel the open experience entry before continuing.");
          return;
        }
        if (currentStep === 5 && window.EmployeeDocumentsWizard?.isFormOpen?.()) {
          validateTab(currentStep, { markInvalid: true });
          updateWizardValidity();
          alert("Please save or cancel the open document entry before continuing.");
          return;
        }

        // Block moving forward only if an education/experience/document sub-form is open
        const ok = validateTab(currentStep, { markInvalid: true });
        updateWizardValidity();
        if (!ok) return;

        if (currentStep < steps.length - 1) {
          currentStep += 1;
          goToStep(currentStep);
          updateWizardButtons();
        }
      });
    }

    if (tabsContainer) {
      tabsContainer.addEventListener("shown.bs.tab", function (event) {
        const target = event.target.getAttribute("data-bs-target");
        if (!target) return;

        const id = target.replace("#", "");
        const idx = steps.indexOf(id);

        if (idx !== -1) {
          currentStep = idx;
          updateWizardButtons();
          updateWizardValidity();
        }
      });
    }

    if (modalEl) {
      modalEl.addEventListener("shown.bs.modal", function () {
        currentStep = 0;
        goToStep(currentStep);
        // Ensure save/next are not blocked by native HTML validation
        clearNativeRequiredConstraints(modalEl);
        markAsteriskFields(modalEl);
        updateWizardButtons();
        updateWizardValidity();
      });

      // Live validation while user edits
      modalEl.addEventListener("input", function (e) {
        const t = e.target;
        if (t && (t.matches("input, select, textarea"))) {
          // remove invalid state as user edits
          if (t.classList.contains("is-invalid") && controlHasValue(t)) {
            t.classList.remove("is-invalid");
          }
          updateWizardValidity();
        }
      });
      modalEl.addEventListener("change", function (e) {
        if (e.target?.name === "reportingManagerId") {
          validateReportingManager({ markInvalid: true });
        }
        updateWizardValidity();
      });
    }

    getReportingManagerSelect()?.addEventListener("change", () => {
      validateReportingManager({ markInvalid: true });
      updateWizardValidity();
    });

    // =======================================
    // "Permanent same as present" helper
    // =======================================
    const sameAsPresentCheckbox = document.getElementById("sameAsPresent");

    if (sameAsPresentCheckbox) {
      sameAsPresentCheckbox.addEventListener("change", function () {
        if (!this.checked) return;

        const copyField = (from, to) => {
          const f = document.querySelector('[name="' + from + '"]');
          const t = document.querySelector('[name="' + to + '"]');
          if (f && t) t.value = f.value;
        };

        copyField("presentAddressLine1", "permanentAddressLine1");
        copyField("presentAddressLine2", "permanentAddressLine2");
        copyField("presentCity", "permanentCity");
        copyField("presentState", "permanentState");
        copyField("presentZip", "permanentZip");
        copyField("presentCountry", "permanentCountry");
      });
    }

    // =======================================
    // Wizards: Education, Experience, Documents
    // =======================================

    if (window.EmployeeEducationWizard) {
      window.EmployeeEducationWizard.init({
        onValidityChange: updateWizardValidity,
      });
    }
    if (window.EmployeeExperienceWizard) {
      window.EmployeeExperienceWizard.init({
        onValidityChange: updateWizardValidity,
      });
    }
    if (window.EmployeeDocumentsWizard) {
      window.EmployeeDocumentsWizard.init({
        onValidityChange: updateWizardValidity,
      });
    }

    function clearInputsInRow(row) {
      row.querySelectorAll("input, select, textarea").forEach((el) => {
        if (el.type === "checkbox") {
          el.checked = false;
        } else {
          el.value = "";
        }
      });
    }

    function cloneRow(container, rowSelector) {
      const firstRow = container.querySelector(rowSelector);
      if (!firstRow) return;
      const clone = firstRow.cloneNode(true);
      clearInputsInRow(clone);
      container.appendChild(clone);
    }

    function resetDynamicSection(container, rowSelector) {
      if (!container) return;

      const rows = container.querySelectorAll(rowSelector);
      rows.forEach((row, idx) => {
        if (idx === 0) {
          clearInputsInRow(row);
        } else {
          row.remove();
        }
      });
    }

    function collectEducationRows() {
      if (window.EmployeeEducationWizard) {
        return window.EmployeeEducationWizard.getEntries();
      }
      return [];
    }

    function collectExperienceRows() {
      if (window.EmployeeExperienceWizard) {
        return window.EmployeeExperienceWizard.getEntries();
      }
      return [];
    }

    function collectDocumentRows() {
      if (window.EmployeeDocumentsWizard) {
        return window.EmployeeDocumentsWizard.getEntries();
      }
      return [];
    }

    // =======================================
    // Helper: reset entire form (for Add mode)
    // =======================================
    function resetEmployeeForm() {
      if (!addEmployeeForm) return;

      addEmployeeForm.reset();
      employeeIdField.value = "";

      if (sameAsPresentCheckbox) {
        sameAsPresentCheckbox.checked = false;
      }

      if (window.EmployeeEducationWizard) {
        window.EmployeeEducationWizard.reset();
      }
      if (window.EmployeeExperienceWizard) {
        window.EmployeeExperienceWizard.reset();
      }
      if (window.EmployeeDocumentsWizard) {
        window.EmployeeDocumentsWizard.reset();
      }

      // Reset gender dropdown display
      updateGenderDropdownDisplay();
      refreshReportingManagerOptions(null);
      const mgrSelect = getReportingManagerSelect();
      if (mgrSelect) mgrSelect.classList.remove("is-invalid");
    }

    // =======================================
    // Helper: populate form from employee data (Edit mode)
    // =======================================
    function fillBaseField(name, value) {
      if (!addEmployeeForm) return;

      const el = addEmployeeForm.elements[name];
      if (!el) return;

      if (el.type === "checkbox") {
        el.checked = !!value;
      } else {
        el.value = value != null ? value : "";
      }

      // Special handling for gender field to update custom dropdown display
      if (name === "gender") {
        updateGenderDropdownDisplay();
      }
    }

    // =======================================
    // Gender Dropdown with Icons - Custom UI
    // =======================================
    function getGenderIcon(value) {
      const icons = {
        "": '<i class="fas fa-circle-dot" style="color: #6b7280;"></i>',
        "Male": '<i class="fas fa-mars gender-icon-male"></i>',
        "Female": '<i class="fas fa-venus gender-icon-female"></i>',
        "Non-binary": '<i class="fas fa-transgender gender-icon-nonbinary"></i>',
        "Prefer not to say": '<i class="fas fa-circle-question gender-icon-prefer-not"></i>'
      };
      return icons[value] || icons[""];
    }

    function getGenderLabel(value) {
      return value || "Select";
    }

    function updateGenderDropdownDisplay() {
      const genderSelect = document.getElementById("genderSelect");
      const genderTrigger = document.getElementById("genderSelectTrigger");
      const genderDropdown = document.getElementById("genderSelectDropdown");

      if (!genderSelect || !genderTrigger || !genderDropdown) return;

      const selectedValue = genderSelect.value;
      const valueSpan = genderTrigger.querySelector(".gender-select-value");

      if (valueSpan) {
        // Rebuild the value span content with icon and text
        valueSpan.innerHTML = getGenderIcon(selectedValue) + 
          '<span class="gender-select-text">' + getGenderLabel(selectedValue) + '</span>';

        if (selectedValue) {
          genderTrigger.classList.remove("placeholder");
        } else {
          genderTrigger.classList.add("placeholder");
        }
      }

      // Update selected state in dropdown options
      const options = genderDropdown.querySelectorAll(".gender-option");
      options.forEach(opt => {
        if (opt.dataset.value === selectedValue) {
          opt.classList.add("selected");
        } else {
          opt.classList.remove("selected");
        }
      });
    }

    function initGenderDropdown() {
      const genderSelect = document.getElementById("genderSelect");
      const genderTrigger = document.getElementById("genderSelectTrigger");
      const genderDropdown = document.getElementById("genderSelectDropdown");
      const genderCustom = document.getElementById("genderSelectCustom");

      if (!genderSelect || !genderTrigger || !genderDropdown || !genderCustom) return;

      // Initialize display
      updateGenderDropdownDisplay();

      // Close dropdown when clicking outside
      document.addEventListener("click", function(e) {
        if (!genderCustom.contains(e.target)) {
          genderCustom.classList.remove("open");
        }
      });

      // Toggle dropdown on trigger click
      genderTrigger.addEventListener("click", function(e) {
        e.stopPropagation();
        e.preventDefault();
        genderCustom.classList.toggle("open");
      });

      // Handle option selection
      const options = genderDropdown.querySelectorAll(".gender-option");
      options.forEach(opt => {
        opt.addEventListener("click", function(e) {
          e.stopPropagation();
          const value = this.dataset.value;
          genderSelect.value = value;
          
          // Trigger change event on original select for form validation
          genderSelect.dispatchEvent(new Event("change", { bubbles: true }));
          
          updateGenderDropdownDisplay();
          genderCustom.classList.remove("open");
        });
      });

      // Sync custom display when original select changes (programmatically)
      genderSelect.addEventListener("change", function() {
        updateGenderDropdownDisplay();
      });
    }

    // Initialize gender dropdown when modal is shown
    const addEmployeeModalEl = document.getElementById("addEmployeeModal");
    if (addEmployeeModalEl) {
      addEmployeeModalEl.addEventListener("shown.bs.modal", function() {
        setTimeout(() => {
          initGenderDropdown();
        }, 100);
      });

      // Also initialize on tab switch (Personal Details tab)
      const basicTab = document.getElementById("basic-tab");
      if (basicTab) {
        basicTab.addEventListener("shown.bs.tab", function() {
          setTimeout(() => {
            initGenderDropdown();
          }, 100);
        });
      }
    }

