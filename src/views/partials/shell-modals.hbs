{{!-- Global modals — must live outside .app-sidebar to avoid z-index trap with Bootstrap backdrop --}}

{{!-- Notification Center (global slide-out panel) --}}
<div class="nc-backdrop" id="notificationCenterBackdrop" aria-hidden="true"></div>
<aside class="notification-center" id="notificationCenter" aria-label="Notifications" aria-hidden="true">
  <div class="nc-header">
    <div>
      <h2 class="nc-title"><i class="fa-solid fa-bell"></i> Notifications</h2>
      <p class="nc-subtitle">Stay updated on payroll, approvals &amp; more</p>
    </div>
    <button type="button" class="nc-close" id="ncCloseBtn" aria-label="Close notifications">
      <i class="fa-solid fa-xmark"></i>
    </button>
  </div>

  <div class="nc-tabs" id="ncCategoryTabs" role="tablist"></div>

  <div class="nc-list" id="ncList">
    <div class="nc-loading"><div class="spinner-border spinner-border-sm text-primary"></div></div>
  </div>

  <div class="nc-footer">
    <button type="button" class="btn btn-sm btn-outline-secondary" id="ncMarkAllBtn">
      <i class="fa-solid fa-check-double me-1"></i> Mark all read
    </button>
    <button type="button" class="btn btn-sm btn-primary" id="ncLoadMoreBtn" style="display:none;">
      Load more
    </button>
  </div>
</aside>

{{!-- Preferences modal --}}
<div class="modal fade" id="preferencesModal" tabindex="-1" aria-labelledby="preferencesModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="preferencesModalLabel"><i class="fa-solid fa-sliders me-2"></i>Preferences</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p class="text-muted small mb-3">Customize your mini-hr-360 experience. Saved on this device.</p>
        <div class="form-check form-switch mb-3">
          <input class="form-check-input" type="checkbox" id="prefNavExpanded" checked>
          <label class="form-check-label" for="prefNavExpanded">Keep navigation menu expanded in sidebar</label>
        </div>
        <div class="form-check form-switch mb-3">
          <input class="form-check-input" type="checkbox" id="prefCompactSidebar">
          <label class="form-check-label" for="prefCompactSidebar">Compact sidebar labels</label>
        </div>
        <div class="form-check form-switch">
          <input class="form-check-input" type="checkbox" id="prefReducedMotion">
          <label class="form-check-label" for="prefReducedMotion">Reduce motion &amp; animations</label>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="preferencesSaveBtn">Save preferences</button>
      </div>
    </div>
  </div>
</div>
