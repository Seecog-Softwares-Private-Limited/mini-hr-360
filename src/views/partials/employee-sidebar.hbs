{{!-- Employee Portal Sidebar — navigation generated from portalNav (RBAC) --}}
<div class="col-md-2 emp-sidebar p-3">
    <div class="emp-brand mb-3">
        <div class="emp-brand-mark">
            <i class="fa-solid fa-user-tie"></i>
        </div>
        <div>
            <div class="emp-brand-title">mini-hr-360</div>
            <div class="emp-brand-subtitle">Employee Portal</div>
        </div>
    </div>

    <div class="emp-profile mb-3">
        <div class="emp-profile-avatar">
            {{#if employee.profilePhoto}}
            <img src="{{employee.profilePhoto}}" alt="" style="width:100%;height:100%;border-radius:50%;object-fit:cover;">
            {{else}}
            {{substring employee.empName 0 1}}
            {{/if}}
        </div>
        <div>
            <div class="emp-profile-name">{{employee.empName}}</div>
            <div class="emp-profile-role">{{employee.empDesignation}}</div>
            {{#if employeeDisplayRole}}
            <div class="emp-profile-role-badge small opacity-75">{{employeeDisplayRole}}</div>
            {{/if}}
        </div>
    </div>

    <div class="emp-divider"></div>

    <nav class="nav flex-column emp-sidebar-nav">
        {{#each portalNav}}
            {{#if this.title}}
                <div class="emp-nav-section">{{this.title}}</div>
                <button type="button" class="emp-nav-toggle" data-emp-nav-toggle="{{this.submenuId}}" aria-expanded="false">
                    <span class="emp-nav-left"><i class="fa-solid {{this.toggleIcon}}"></i> {{this.toggleLabel}}</span>
                    <i class="fa-solid fa-chevron-down"></i>
                </button>
                <div id="{{this.submenuId}}" class="emp-nav-submenu">
                    {{#each this.items}}
                    <a class="nav-link {{#if (navActive ../active this.key)}}active{{/if}}{{#if this.comingSoon}} coming-soon{{/if}}"
                       href="{{this.href}}"
                       {{#if this.external}}target="_blank" rel="noopener noreferrer"{{/if}}>
                        {{#if this.icon}}<i class="fa-solid {{this.icon}}"></i>{{/if}}
                        {{this.label}}
                        {{#if this.external}}<i class="fa-solid fa-arrow-up-right-from-square ms-1 small opacity-50"></i>{{/if}}
                    </a>
                    {{/each}}
                </div>
            {{else}}
                {{#each this.items}}
                <a class="nav-link {{#if (navActive ../active this.key)}}active{{/if}}"
                   href="{{this.href}}"
                   {{#if this.external}}target="_blank" rel="noopener noreferrer"{{/if}}>
                    {{#if this.icon}}<i class="fa-solid {{this.icon}}"></i>{{/if}}
                    {{this.label}}
                </a>
                {{/each}}
                {{#unless @last}}<div class="emp-divider"></div>{{/unless}}
            {{/if}}
        {{/each}}

        <div class="emp-divider"></div>
        <a class="nav-link text-danger" href="/employee/logout">
            <i class="fa-solid fa-right-from-bracket"></i> Logout
        </a>
    </nav>
</div>
