{{!-- Shared employee portal lifecycle summary card --}}
{{#if lifecycle}}
<article class="emp-card mb-4" id="emp-lifecycle-card">
  <div class="emp-card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
    <h5 class="emp-card-title mb-0">
      <i class="fa-solid fa-route" style="color:#8b5cf6;"></i> My Employment
    </h5>
    {{#if lifecycle.showHrLettersLink}}
      <a href="/employee/hr-letters" class="btn btn-sm btn-outline-primary">HR Letters</a>
    {{/if}}
  </div>
  <div class="emp-card-body">
    <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
      <span class="badge bg-primary">{{lifecycle.lifecycleStageLabel}}</span>
      <span class="text-muted small">{{lifecycle.employeeType}}</span>
      {{#if lifecycle.employmentStatus}}
        <span class="badge bg-light text-dark border">{{lifecycle.employmentStatus}}</span>
      {{/if}}
    </div>
    <p class="small text-muted mb-2">{{lifecycle.statusMessage}}</p>
    <div class="progress mb-2" style="height:6px;">
      <div class="progress-bar bg-primary" style="width: {{lifecycle.progressPercent}}%;"></div>
    </div>
    {{#if lifecycle.probationEndDate}}
      <p class="small mb-1"><i class="fa-solid fa-hourglass-half me-1 text-muted"></i> Probation ends: {{lifecycle.probationEndDate}}</p>
    {{/if}}
    {{#if lifecycle.contractEndDate}}
      <p class="small mb-1"><i class="fa-solid fa-file-contract me-1 text-muted"></i> Contract ends: {{lifecycle.contractEndDate}}</p>
    {{/if}}
    {{#if lifecycle.unacknowledgedLetters}}
      <div class="alert alert-warning py-2 px-3 small mb-0 mt-2">
        <i class="fa-solid fa-circle-exclamation me-1"></i>
        {{lifecycle.unacknowledgedLetters}} letter(s) awaiting acknowledgement
      </div>
    {{/if}}
  </div>
</article>
{{/if}}
