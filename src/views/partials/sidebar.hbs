<aside class="sidebar-inner" aria-label="Main navigation">
  <div class="sidebar-app-tag">mini-hr-360</div>

  <div class="sidebar-profile">
    <div class="profile-avatar">
      {{#if user.avatarUrl}}
      <img src="{{user.avatarUrl}}" alt="" style="width:100%;height:100%;border-radius:50%;object-fit:cover;">
      {{else}}
      <i class="fa-solid fa-user"></i>
      {{/if}}
    </div>
    <div class="profile-meta">
      <div class="profile-name">
        {{#if user.firstName}}{{user.firstName}}{{else}}User{{/if}}
        {{#if user.lastName}} {{user.lastName}}{{/if}}
      </div>
      <div class="profile-role">
        {{#if user.role}}
          {{#if (eq user.role 'HR_MANAGER')}}HR Manager{{else if (eq user.role 'HR_EXECUTIVE')}}HR Executive{{else if (eq user.role 'FINANCE')}}Finance{{else if (eq user.role 'MANAGER')}}Manager{{else if (eq user.role 'EMPLOYEE')}}Employee{{else if (eq user.role 'shop_manager')}}Shop Manager{{else if (eq user.role 'shop_worker')}}Shop Worker{{else if (eq user.role 'shop_owner')}}Owner{{else if (eq user.role 'admin')}}Administrator{{else if (eq user.role 'SUPER_ADMIN')}}Super Admin{{else}}{{user.role}}{{/if}}
        {{else}}Administrator{{/if}}
      </div>
    </div>
  </div>

  <div class="sidebar-scroll">
    <nav class="sidebar-nav" aria-label="Main navigation">
        <a class="sidebar-link {{#if (eq active 'dashboard')}}active{{/if}}" href="/dashboard" data-nav="dashboard">
          <i class="fa-solid fa-gauge-high nav-icon"></i> Dashboard
        </a>
        <a class="sidebar-link {{#if (eq active 'business')}}active{{/if}}" href="/business" data-nav="business">
          <i class="fa-solid fa-building nav-icon"></i> Company Profile
        </a>
        <a class="sidebar-link {{#if (eq active 'employees')}}active{{/if}}" href="/employees" data-nav="employees">
          <i class="fa-solid fa-user-tie nav-icon"></i> Employees
        </a>
        <a class="sidebar-link {{#if (eq active 'candidates')}}active{{/if}}" href="/candidates" data-nav="candidates">
          <i class="fa-solid fa-user-group nav-icon"></i> Candidates
        </a>

        <button type="button" class="sidebar-link {{#if (startswith active 'attendance')}}active{{/if}}" data-menu-toggle="attendance-submenu" onclick="toggleMenu('attendance-submenu')">
          <i class="fa-solid fa-clock nav-icon"></i>
          <span>Attendance</span>
          <i class="fa-solid fa-chevron-down nav-chevron {{#if (startswith active 'attendance')}}open{{/if}}"></i>
        </button>
        <div class="sidebar-submenu {{#if (startswith active 'attendance')}}show{{/if}}" id="attendance-submenu">
          <a class="sidebar-link {{#if (eq active 'attendance-dashboard')}}active{{/if}}" href="/admin/attendance"><i class="fa-solid fa-gauge nav-icon"></i> Dashboard</a>
          <a class="sidebar-link {{#if (eq active 'attendance-policies')}}active{{/if}}" href="/admin/attendance/policies"><i class="fa-solid fa-file-contract nav-icon"></i> Policies</a>
          <a class="sidebar-link {{#if (eq active 'attendance-shifts')}}active{{/if}}" href="/admin/attendance/shifts"><i class="fa-solid fa-clock nav-icon"></i> Shifts</a>
          <a class="sidebar-link {{#if (eq active 'attendance-holidays')}}active{{/if}}" href="/admin/attendance/holidays"><i class="fa-solid fa-calendar-day nav-icon"></i> Holidays</a>
          <a class="sidebar-link {{#if (eq active 'attendance-assignments')}}active{{/if}}" href="/admin/attendance/assignments"><i class="fa-solid fa-user-tag nav-icon"></i> Assignments</a>
          <a class="sidebar-link {{#if (eq active 'attendance-logs')}}active{{/if}}" href="/admin/attendance/logs"><i class="fa-solid fa-book nav-icon"></i> Logs</a>
          <a class="sidebar-link {{#if (eq active 'attendance-summaries')}}active{{/if}}" href="/admin/attendance/summaries"><i class="fa-solid fa-users-viewfinder nav-icon"></i> Employee Summaries</a>
          <a class="sidebar-link {{#if (eq active 'attendance-regularizations')}}active{{/if}}" href="/admin/attendance/regularizations"><i class="fa-solid fa-pen-ruler nav-icon"></i> Regularizations</a>
          <a class="sidebar-link {{#if (eq active 'attendance-reports')}}active{{/if}}" href="/admin/attendance/reports"><i class="fa-solid fa-chart-line nav-icon"></i> Reports</a>
          <a class="sidebar-link {{#if (eq active 'attendance-lock')}}active{{/if}}" href="/admin/attendance/lock"><i class="fa-solid fa-lock nav-icon"></i> Lock</a>
        </div>

        <button type="button" class="sidebar-link {{#if (startswith active 'payroll')}}active{{/if}}" data-menu-toggle="payroll-submenu" onclick="toggleMenu('payroll-submenu')">
          <i class="fa-solid fa-money-bill-wave nav-icon"></i>
          <span>Payroll</span>
          <i class="fa-solid fa-chevron-down nav-chevron {{#if (startswith active 'payroll')}}open{{/if}}"></i>
        </button>
        <div class="sidebar-submenu {{#if (startswith active 'payroll')}}show{{/if}}" id="payroll-submenu">
          <a class="sidebar-link {{#if (eq active 'payroll-setup')}}active{{/if}}" href="/admin/payroll/setup"><i class="fa-solid fa-cogs nav-icon"></i> Setup</a>
          <a class="sidebar-link {{#if (eq active 'payroll-structures')}}active{{/if}}" href="/admin/payroll/structures"><i class="fa-solid fa-sitemap nav-icon"></i> Structures</a>
          <a class="sidebar-link {{#if (eq active 'payroll-runs')}}active{{/if}}" href="/admin/payroll/runs"><i class="fa-solid fa-play-circle nav-icon"></i> Runs</a>
          <a class="sidebar-link {{#if (eq active 'payroll-register')}}active{{/if}}" href="/admin/payroll/register"><i class="fa-solid fa-list nav-icon"></i> Register</a>
          <a class="sidebar-link {{#if (eq active 'payroll-payslips')}}active{{/if}}" href="/admin/payroll/payslips"><i class="fa-solid fa-file-invoice-dollar nav-icon"></i> Payslips</a>
          <a class="sidebar-link {{#if (eq active 'payroll-statutory')}}active{{/if}}" href="/admin/payroll/statutory"><i class="fa-solid fa-scale-balanced nav-icon"></i> Statutory</a>
          <a class="sidebar-link {{#if (eq active 'payroll-queries')}}active{{/if}}" href="/admin/payroll/queries"><i class="fa-solid fa-comments nav-icon"></i> Queries</a>
        </div>

        <a class="sidebar-link {{#if (eq active 'documents')}}active{{/if}}" href="/documents" data-nav="documents">
          <i class="fa-solid fa-file-signature nav-icon"></i> Documents
        </a>
        <a class="sidebar-link {{#if (eq active 'documentApprovals')}}active{{/if}}" href="/document-approvals" data-nav="documentApprovals">
          <i class="fa-solid fa-hourglass-half nav-icon"></i> Doc Approvals
        </a>
        <a class="sidebar-link {{#if (eq active 'documentTypes')}}active{{/if}}" href="/document-types" data-nav="documentTypes">
          <i class="fa-solid fa-layer-group nav-icon"></i> Document Types
        </a>

        <button type="button" class="sidebar-link {{#if (or (eq active 'leaveRequests') (or (eq active 'leaveTypes') (eq active 'leaveBalances')))}}active{{/if}}" data-menu-toggle="leave-submenu" onclick="toggleMenu('leave-submenu')">
          <i class="fa-solid fa-calendar-check nav-icon"></i>
          <span>Leave</span>
          <i class="fa-solid fa-chevron-down nav-chevron {{#if (or (eq active 'leaveRequests') (or (eq active 'leaveTypes') (eq active 'leaveBalances')))}}open{{/if}}"></i>
        </button>
        <div class="sidebar-submenu {{#if (or (eq active 'leaveRequests') (or (eq active 'leaveTypes') (eq active 'leaveBalances')))}}show{{/if}}" id="leave-submenu">
          <a class="sidebar-link {{#if (eq active 'leaveRequests')}}active{{/if}}" href="/leave-requests"><i class="fa-solid fa-clipboard-list nav-icon"></i> Requests</a>
          <a class="sidebar-link {{#if (eq active 'leaveTypes')}}active{{/if}}" href="/leave-requests/leave-types"><i class="fa-solid fa-tags nav-icon"></i> Types</a>
          <a class="sidebar-link {{#if (eq active 'leaveBalances')}}active{{/if}}" href="/leave-requests/leave-balances"><i class="fa-solid fa-scale-balanced nav-icon"></i> Balances</a>
        </div>

        <a class="sidebar-link {{#if (eq active 'departments')}}active{{/if}}" href="/departments" data-nav="departments">
          <i class="fa-solid fa-building-columns nav-icon"></i> Departments
        </a>
        <a class="sidebar-link {{#if (eq active 'designations')}}active{{/if}}" href="/designations" data-nav="designations">
          <i class="fa-solid fa-id-badge nav-icon"></i> Designations
        </a>
        <a class="sidebar-link {{#if (eq active 'team')}}active{{/if}}" href="/admin/team" data-nav="team">
          <i class="fa-solid fa-users-gear nav-icon"></i> Manage Roles &amp; People
        </a>
        <a class="sidebar-link {{#if (eq active 'emailTemplates')}}active{{/if}}" href="/email-templates" data-nav="emailTemplates">
          <i class="fa-solid fa-envelope-open-text nav-icon"></i> Email Templates
        </a>
    </nav>

    <div class="sidebar-section-label">Account</div>
    <nav class="sidebar-nav sidebar-footer" aria-label="Account navigation">
      <a class="sidebar-link {{#if (eq active 'profile')}}active{{/if}}" href="/admin/profile" data-nav="settings">
        <i class="fa-solid fa-gear nav-icon"></i> Settings
      </a>
      <a class="sidebar-link {{#if (eq active 'billing')}}active{{/if}}" href="/billing" data-nav="billing">
        <i class="fa-solid fa-crown nav-icon"></i> Billing &amp; Plan
      </a>
      <button type="button" class="sidebar-link" data-nav="notifications">
        <i class="fa-solid fa-bell nav-icon"></i> Notifications
        <span class="badge bg-danger ms-auto" id="sidebarNotificationBadge" style="display: none; font-size: 10px;">0</span>
      </button>
      <button type="button" class="sidebar-link logout-link" onclick="logout(); return false;">
        <i class="fa-solid fa-right-from-bracket nav-icon"></i> Logout
      </button>
    </nav>
  </div>
</aside>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const userRole = localStorage.getItem('userRole') || '{{user.role}}' || 'admin';
    const lockableSelector = '.app-sidebar .sidebar-link, .app-sidebar [data-menu-toggle]';

    const rolePermissions = {
      admin: { all: true },
      SUPER_ADMIN: { all: true },
      shop_owner: { all: true },
      HR_MANAGER: { dashboard: true, business: false, employees: true, leaves: true, attendance: true, payroll: true, payrollSetup: false, payrollStructures: false, documents: true, templates: false, departments: false, designations: false, businessAddresses: false, team: false, billing: false, profile: true },
      HR_EXECUTIVE: { dashboard: true, business: false, employees: true, leaves: true, attendance: true, payroll: true, payrollSetup: false, payrollStructures: false, documents: true, templates: false, departments: false, designations: false, businessAddresses: false, team: false, billing: false, profile: true },
      FINANCE: { dashboard: true, business: false, employees: false, leaves: false, attendance: false, payroll: true, payrollSetup: false, payrollStructures: false, documents: false, templates: false, departments: false, designations: false, businessAddresses: false, team: false, billing: true, profile: true },
      MANAGER: { dashboard: true, business: false, employees: false, leaves: true, attendance: true, payroll: false, documents: false, templates: false, departments: false, designations: false, businessAddresses: false, team: false, billing: false, profile: true },
    };

    const permissions = rolePermissions[userRole] || {};
    const isFullAdmin = permissions.all === true;
    const showOnlyOrganizationsAccess = () => {
      document.querySelectorAll(lockableSelector).forEach((el) => {
        const href = el.getAttribute('href') || '';
        const isOrganizationsLink = href === '/business';
        const isLogout = el.classList.contains('logout-link');
        const canKeepEnabled = isOrganizationsLink || isLogout;
        if (!canKeepEnabled) {
          el.classList.add('disabled');
          el.style.pointerEvents = 'none';
          el.style.opacity = '0.5';
        }
      });

      const infoId = 'org-required-sidebar-alert';
      if (!document.getElementById(infoId)) {
        const hint = document.createElement('div');
        hint.id = infoId;
        hint.className = 'mt-2 mb-0 px-3 py-3 small';
        hint.style.cssText = 'background: linear-gradient(135deg, rgba(250,204,21,0.22), rgba(245,158,11,0.18)); border: 1px solid rgba(250,204,21,0.45); border-radius: 12px; color: #fde68a;';
        hint.innerHTML = `
          <div style="display:flex; gap:10px; align-items:flex-start;">
            <i class="fa-solid fa-circle-info" style="margin-top:2px; color:#facc15;"></i>
            <div>
              <div style="font-weight:700; color:#fef3c7;">Organization Required</div>
              <div style="opacity:0.95;">Create or join an organization to unlock the menu.</div>
            </div>
          </div>
        `;
        document.querySelector('.app-sidebar .sidebar-scroll')?.prepend(hint);
      }
    };

    if (!isFullAdmin) {
      const hideLink = (href) => {
        const link = document.querySelector(`.app-sidebar a[href="${href}"]`);
        if (link) link.style.display = 'none';
      };

      if (!permissions.business) hideLink('/business');
      if (!permissions.employees) hideLink('/employees');
      if (!permissions.leaves) {
        document.querySelector('[data-menu-toggle="leave-submenu"]')?.style.setProperty('display', 'none');
        document.getElementById('leave-submenu')?.style.setProperty('display', 'none');
      }
      if (!permissions.attendance) {
        document.querySelector('[data-menu-toggle="attendance-submenu"]')?.style.setProperty('display', 'none');
        document.getElementById('attendance-submenu')?.style.setProperty('display', 'none');
      }
      if (!permissions.payroll) {
        document.querySelector('[data-menu-toggle="payroll-submenu"]')?.style.setProperty('display', 'none');
        document.getElementById('payroll-submenu')?.style.setProperty('display', 'none');
      } else {
        if (!permissions.payrollSetup) hideLink('/admin/payroll/setup');
        if (!permissions.payrollStructures) hideLink('/admin/payroll/structures');
      }
      if (!permissions.documents) hideLink('/documents');
      if (!permissions.templates) {
        hideLink('/document-types');
        hideLink('/email-templates');
      }
      if (!permissions.departments) hideLink('/departments');
      if (!permissions.designations) hideLink('/designations');
      if (!permissions.businessAddresses) hideLink('/business-addresses');
      if (!permissions.team) hideLink('/admin/team');
      if (!permissions.billing) hideLink('/billing');
    }

    // Enforce organization-first flow only for restricted roles without full workspace access.
    if (!isFullAdmin && typeof window.apiCall === 'function') {
      window.apiCall('/business/capabilities', { skipWorkspace: true })
        .then((data) => {
          const caps = data?.data || data || {};
          if (!caps.hasOrganization) showOnlyOrganizationsAccess();
        })
        .catch((err) => {
          // Do not lock navigation on transient API failures when org context already exists.
          const hasOrgContext = typeof getOrganizationId === 'function' && !!getOrganizationId();
          if (!hasOrgContext) {
            console.warn('Organization capability check failed:', err?.message || err);
            showOnlyOrganizationsAccess();
          }
        });
    }
  });

</script>
