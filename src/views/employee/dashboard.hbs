<div class="container-fluid">
    <div class="row">
        {{> employee-sidebar employee=employee active='dashboard'}}

        <div class="col-md-10 emp-main">
            <!-- Hero -->
            <div class="emp-hero">
                <div class="row align-items-center position-relative" style="z-index:1;">
                    <div class="col-md-8">
                        <div class="emp-hero-greeting">{{overview.greeting}} {{employee.firstName}} 👋</div>
                        <p class="emp-hero-sub mb-0">
                            You worked <strong>{{overview.workedDaysThisMonth}}</strong> days this month
                            {{#if overview.attendanceRate}} · <strong>{{overview.attendanceRate}}%</strong> attendance{{/if}}
                        </p>
                        <div class="emp-hero-stats">
                            <div class="emp-hero-stat">
                                <i class="fa-solid fa-money-bill-wave me-1"></i>
                                Salary in <strong>{{overview.salaryInDays}}</strong> day{{#unless (eq overview.salaryInDays 1)}}s{{/unless}}
                            </div>
                            {{#if employee.shiftName}}
                            <div class="emp-hero-stat">
                                <i class="fa-solid fa-clock me-1"></i>
                                {{employee.shiftName}} · {{employee.shiftStartTime}}–{{employee.shiftEndTime}}
                            </div>
                            {{/if}}
                        </div>
                    </div>
                    <div class="col-md-4 text-md-end mt-3 mt-md-0">
                        <a href="/employee/attendance/today" class="btn btn-light btn-sm fw-bold me-2">
                            <i class="fa-solid fa-fingerprint me-1"></i> Clock In/Out
                        </a>
                        <a href="/employee/leaves/apply" class="btn btn-outline-light btn-sm fw-bold">
                            <i class="fa-solid fa-plus me-1"></i> Apply Leave
                        </a>
                    </div>
                </div>
            </div>

            <!-- KPI Cards -->
            <div class="emp-kpi-grid">
                <a href="/employee/attendance/calendar" class="emp-kpi-card">
                    <div class="emp-kpi-icon" style="background: linear-gradient(135deg, #f97316, #ea580c);">
                        <i class="fa-solid fa-fire"></i>
                    </div>
                    <div class="emp-kpi-value" data-kpi="streak">{{overview.attendanceStreak}}</div>
                    <div class="emp-kpi-label">Attendance Streak</div>
                    <div class="emp-kpi-hint">Consecutive present days</div>
                </a>

                <a href="/employee/payroll/payslips" class="emp-kpi-card">
                    <div class="emp-kpi-icon" style="background: linear-gradient(135deg, #22c55e, #16a34a);">
                        <i class="fa-solid fa-indian-rupee-sign"></i>
                    </div>
                    <div class="emp-kpi-value" data-kpi="salaryDays">{{overview.salaryInDays}}d</div>
                    <div class="emp-kpi-label">Upcoming Salary</div>
                    <div class="emp-kpi-hint">
                        {{#if overview.estimatedMonthlySalary}}~₹{{overview.estimatedMonthlySalary}} · {{/if}}Pay day {{overview.payDay}}
                    </div>
                </a>

                <a href="/employee/leaves" class="emp-kpi-card">
                    <div class="emp-kpi-icon" style="background: linear-gradient(135deg, #8b5cf6, #7c3aed);">
                        <i class="fa-solid fa-umbrella-beach"></i>
                    </div>
                    <div class="emp-kpi-value" data-kpi="leaveBalance">{{overview.remainingLeave}}</div>
                    <div class="emp-kpi-label">Remaining Leave</div>
                    <div class="emp-kpi-hint">Days available across types</div>
                </a>

                <a href="/employee/leaves?status=PENDING" class="emp-kpi-card">
                    <div class="emp-kpi-icon" style="background: linear-gradient(135deg, #f59e0b, #d97706);">
                        <i class="fa-solid fa-hourglass-half"></i>
                    </div>
                    <div class="emp-kpi-value" data-kpi="pendingApprovals">{{overview.pendingApprovals}}</div>
                    <div class="emp-kpi-label">Pending Approvals</div>
                    <div class="emp-kpi-hint">Leaves & regularizations</div>
                </a>

                <a href="/employee/work/tasks" class="emp-kpi-card">
                    <div class="emp-kpi-icon" style="background: linear-gradient(135deg, #0ea5e9, #0284c7);">
                        <i class="fa-solid fa-list-check"></i>
                    </div>
                    <div class="emp-kpi-value" data-kpi="tasks">{{overview.tasksSummary.pending}}</div>
                    <div class="emp-kpi-label">Tasks</div>
                    <div class="emp-kpi-hint">Coming soon</div>
                </a>
            </div>

            <div class="row g-4">
                <!-- Announcements -->
                <div class="col-lg-4">
                    <div class="emp-card h-100">
                        <div class="emp-card-header">
                            <h5 class="emp-card-title">
                                <i class="fa-solid fa-bullhorn" style="color: var(--emp-primary);"></i>
                                Announcements
                            </h5>
                        </div>
                        <div class="emp-card-body" id="announcementsFeed">
                            {{#each overview.announcements}}
                            <div class="emp-feed-item">
                                <div class="emp-feed-icon" style="background: rgba(14,165,233,0.12); color: var(--emp-primary);">
                                    <i class="fa-solid fa-{{#if (eq this.type 'salary')}}money-bill{{else}}{{#if (eq this.type 'team')}}users{{else}}info-circle{{/if}}{{/if}}"></i>
                                </div>
                                <div>
                                    <div class="fw-bold" style="font-size:14px;">{{this.title}}</div>
                                    <div class="text-muted" style="font-size:13px;">{{this.body}}</div>
                                </div>
                            </div>
                            {{/each}}
                        </div>
                    </div>
                </div>

                <!-- Team Birthdays -->
                <div class="col-lg-4">
                    <div class="emp-card h-100">
                        <div class="emp-card-header">
                            <h5 class="emp-card-title">
                                <i class="fa-solid fa-cake-candles" style="color: #ec4899;"></i>
                                Team Birthdays
                            </h5>
                        </div>
                        <div class="emp-card-body" id="birthdaysFeed">
                            {{#if overview.teamBirthdays.length}}
                                {{#each overview.teamBirthdays}}
                                <div class="emp-birthday-item">
                                    <div class="emp-birthday-avatar">{{this.name.[0]}}</div>
                                    <div>
                                        <div class="fw-bold" style="font-size:14px;">{{this.name}}</div>
                                        <div class="text-muted" style="font-size:12px;">{{this.department}} · {{this.day}}th this month</div>
                                    </div>
                                </div>
                                {{/each}}
                            {{else}}
                                <div class="text-center py-4 text-muted">
                                    <i class="fa-solid fa-cake-candles fa-2x mb-2 opacity-50"></i>
                                    <p class="mb-0 small">No birthdays this month</p>
                                </div>
                            {{/if}}
                        </div>
                    </div>
                </div>

                <!-- Recent Requests -->
                <div class="col-lg-4">
                    <div class="emp-card h-100">
                        <div class="emp-card-header">
                            <h5 class="emp-card-title">
                                <i class="fa-solid fa-history" style="color: var(--emp-primary);"></i>
                                Recent Leaves
                            </h5>
                            <a href="/employee/leaves" class="btn emp-btn-secondary btn-sm">View all</a>
                        </div>
                        <div class="emp-card-body p-0">
                            {{#if recentRequests.length}}
                            <table class="emp-table mb-0">
                                <tbody>
                                    {{#each recentRequests}}
                                    <tr>
                                        <td>
                                            <div style="font-weight:600;font-size:14px;">{{this.leaveType}}</div>
                                            <small class="text-muted">{{this.startDate}} – {{this.endDate}}</small>
                                        </td>
                                        <td class="text-end">
                                            <span class="emp-badge {{#if (eq this.status 'PENDING')}}emp-badge-pending{{/if}}{{#if (eq this.status 'APPROVED')}}emp-badge-approved{{/if}}{{#if (eq this.status 'REJECTED')}}emp-badge-rejected{{/if}}{{#if (eq this.status 'CANCELED')}}emp-badge-canceled{{/if}}">
                                                {{this.status}}
                                            </span>
                                        </td>
                                    </tr>
                                    {{/each}}
                                </tbody>
                            </table>
                            {{else}}
                            <div class="text-center py-4 text-muted">
                                <p class="mb-2">No recent requests</p>
                                <a href="/employee/leaves/apply" class="btn emp-btn-primary btn-sm">Apply Leave</a>
                            </div>
                            {{/if}}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Leave Balances -->
            {{#if leaveStats.balances.length}}
            <div class="emp-card mt-4">
                <div class="emp-card-header">
                    <h5 class="emp-card-title">
                        <i class="fa-solid fa-wallet" style="color: var(--emp-primary);"></i>
                        Leave Balances
                    </h5>
                </div>
                <div class="emp-card-body">
                    <div class="row g-3">
                        {{#each leaveStats.balances}}
                        <div class="col-md-2 col-sm-4 col-6">
                            <div class="leave-balance-card">
                                <div class="leave-balance-type" style="color: {{this.color}};">{{this.leaveTypeName}}</div>
                                <div class="leave-balance-value" style="color: {{this.color}};">{{this.available}}</div>
                                <div class="leave-balance-label">Available</div>
                            </div>
                        </div>
                        {{/each}}
                    </div>
                </div>
            </div>
            {{/if}}
        </div>
    </div>
</div>

<script src="/assets/js/employee-dashboard.js"></script>
