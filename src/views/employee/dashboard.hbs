<div class="container-fluid">
    <div class="row">
        {{> employee-sidebar employee=employee active='dashboard' portalNav=portalNav portalAccess=portalAccess portalRole=portalRole}}

        <div class="col-md-10 emp-main">
            <!-- Hero -->
            <div class="emp-hero">
                <div class="row align-items-center position-relative" style="z-index:1;">
                    <div class="col-lg-8">
                        <div class="emp-hero-greeting">{{overview.greeting}}, {{employee.firstName}} 👋</div>
                        <p class="emp-hero-sub mb-0">
                            Your home for attendance, leave, pay, and daily tasks.
                            {{#if business.name}}<span class="opacity-75">· {{business.name}}</span>{{/if}}
                        </p>
                    </div>
                    <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
                        <span class="emp-hero-date">
                            <i class="fa-solid fa-calendar-day me-1"></i>
                            <span id="empHomeDate">{{overview.today}}</span>
                        </span>
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="emp-quick-actions" role="toolbar" aria-label="Quick actions">
                <a href="/employee/attendance/today" class="emp-quick-action emp-quick-action-primary">
                    <i class="fa-solid fa-fingerprint"></i>
                    <span>Clock In/Out</span>
                </a>
                <a href="/employee/leaves/apply" class="emp-quick-action">
                    <i class="fa-solid fa-calendar-plus"></i>
                    <span>Apply Leave</span>
                </a>
                <a href="/employee/payroll/payslips" class="emp-quick-action">
                    <i class="fa-solid fa-file-invoice-dollar"></i>
                    <span>Payslips</span>
                </a>
                <a href="/employee/attendance/regularization_form" class="emp-quick-action">
                    <i class="fa-solid fa-pen-ruler"></i>
                    <span>Regularize</span>
                </a>
                <a href="/employee/payroll/queries" class="emp-quick-action">
                    <i class="fa-solid fa-circle-question"></i>
                    <span>Payroll Query</span>
                </a>
                <a href="/employee/attendance/calendar" class="emp-quick-action">
                    <i class="fa-solid fa-calendar"></i>
                    <span>Calendar</span>
                </a>
                {{#if portalAccess.canViewTeam}}
                <a href="/employee/team" class="emp-quick-action">
                    <i class="fa-solid fa-users"></i>
                    <span>Team</span>
                </a>
                {{/if}}
            </div>

            <!-- Home Widgets -->
            <div class="emp-home-grid">
                <!-- Today Attendance -->
                <article class="emp-home-widget" id="widget-attendance">
                    <div class="emp-home-widget-header">
                        <h3><i class="fa-solid fa-fingerprint" style="color:#0ea5e9;"></i> Today Attendance</h3>
                        <a href="/employee/attendance/today" class="emp-home-view-all">View All <i class="fa-solid fa-arrow-right"></i></a>
                    </div>
                    <div class="emp-home-widget-body" id="widget-attendance-body">
                        <div class="emp-widget-status emp-widget-status-{{overview.todayAttendance.statusClass}}" data-attendance-status>
                            {{overview.todayAttendance.statusLabel}}
                        </div>
                        <div class="emp-widget-metrics">
                            <div class="emp-widget-metric">
                                <span class="label">Clock in</span>
                                <strong data-attendance-in>{{#if overview.todayAttendance.clockIn}}{{overview.todayAttendance.clockIn}}{{else}}—{{/if}}</strong>
                            </div>
                            <div class="emp-widget-metric">
                                <span class="label">Clock out</span>
                                <strong data-attendance-out>{{#if overview.todayAttendance.clockOut}}{{overview.todayAttendance.clockOut}}{{else}}—{{/if}}</strong>
                            </div>
                            <div class="emp-widget-metric">
                                <span class="label">Worked</span>
                                <strong data-attendance-worked>{{overview.todayAttendance.workDuration}}</strong>
                            </div>
                        </div>
                        {{#if overview.todayAttendance.shift}}
                        <div class="emp-widget-hint">
                            <i class="fa-solid fa-clock me-1"></i>
                            {{overview.todayAttendance.shift.name}} · {{overview.todayAttendance.shift.startTime}}–{{overview.todayAttendance.shift.endTime}}
                        </div>
                        {{/if}}
                        {{#unless overview.todayAttendance.clockIn}}
                        <a href="/employee/attendance/today" class="emp-widget-cta">
                            <i class="fa-solid fa-arrow-right-to-bracket me-1"></i> Clock in now
                        </a>
                        {{/unless}}
                    </div>
                </article>

                <!-- Leave Balance -->
                <article class="emp-home-widget" id="widget-leaves">
                    <div class="emp-home-widget-header">
                        <h3><i class="fa-solid fa-umbrella-beach" style="color:#8b5cf6;"></i> Leave Balance</h3>
                        <a href="/employee/leaves" class="emp-home-view-all">View All <i class="fa-solid fa-arrow-right"></i></a>
                    </div>
                    <div class="emp-home-widget-body" id="widget-leaves-body">
                        {{#if overview.leaveBalances.length}}
                        <div class="emp-leave-total">
                            <span class="emp-leave-total-value" data-leave-total>{{overview.remainingLeave}}</span>
                            <span class="emp-leave-total-label">days available</span>
                        </div>
                        <div class="emp-leave-breakdown" id="leaveBalanceList">
                            {{#each overview.leaveBalances}}
                            <div class="emp-leave-row">
                                <span class="emp-leave-dot" style="background:{{this.color}};"></span>
                                <span class="emp-leave-name">{{this.name}}</span>
                                <strong class="emp-leave-days" data-leave-type="{{this.id}}">{{this.available}}</strong>
                            </div>
                            {{/each}}
                        </div>
                        {{else}}
                        <div class="emp-widget-empty">
                            <i class="fa-solid fa-umbrella-beach"></i>
                            <p>No leave balances yet</p>
                            <a href="/employee/leaves" class="btn emp-btn-secondary btn-sm">View leaves</a>
                        </div>
                        {{/if}}
                    </div>
                </article>

                <!-- Upcoming Salary -->
                <article class="emp-home-widget" id="widget-salary">
                    <div class="emp-home-widget-header">
                        <h3><i class="fa-solid fa-indian-rupee-sign" style="color:#22c55e;"></i> Upcoming Salary</h3>
                        <a href="/employee/payroll/payslips" class="emp-home-view-all">View All <i class="fa-solid fa-arrow-right"></i></a>
                    </div>
                    <div class="emp-home-widget-body">
                        <div class="emp-salary-countdown">
                            <span class="emp-salary-days" data-salary-days>{{overview.salaryInDays}}</span>
                            <span class="emp-salary-days-label">day{{#unless (eq overview.salaryInDays 1)}}s{{/unless}} to payday</span>
                        </div>
                        <div class="emp-widget-hint">
                            Pay day: <strong>{{overview.payDay}}</strong> of each month
                        </div>
                        {{#if overview.estimatedMonthlySalary}}
                        <div class="emp-salary-estimate">
                            Est. monthly <strong data-salary-estimate>₹{{overview.estimatedMonthlySalary}}</strong>
                        </div>
                        {{/if}}
                        <a href="/employee/payroll/salary-details" class="emp-widget-cta subtle">
                            View salary details <i class="fa-solid fa-arrow-right ms-1"></i>
                        </a>
                    </div>
                </article>

                <!-- Employment lifecycle -->
                {{#if overview.lifecycle}}
                {{> employee-lifecycle-widget lifecycle=overview.lifecycle}}
                {{/if}}

                <!-- Tasks -->
                <article class="emp-home-widget" id="widget-tasks">
                    <div class="emp-home-widget-header">
                        <h3><i class="fa-solid fa-list-check" style="color:#3b82f6;"></i> Tasks</h3>
                        <a href="/employee/work/tasks" class="emp-home-view-all">View All <i class="fa-solid fa-arrow-right"></i></a>
                    </div>
                    <div class="emp-home-widget-body" id="widget-tasks-body">
                        {{#if overview.tasksSummary.total}}
                        <div class="emp-tasks-summary">
                            <div class="emp-tasks-stat">
                                <span class="value" data-tasks-pending>{{overview.tasksSummary.pending}}</span>
                                <span class="label">Pending</span>
                            </div>
                            <div class="emp-tasks-stat">
                                <span class="value" data-tasks-completed>{{overview.tasksSummary.completed}}</span>
                                <span class="label">Done</span>
                            </div>
                        </div>
                        {{else}}
                        <div class="emp-widget-empty">
                            <i class="fa-solid fa-list-check"></i>
                            <p>No tasks assigned yet</p>
                            <span class="badge bg-light text-muted border">Coming soon</span>
                        </div>
                        {{/if}}
                    </div>
                </article>

                <!-- Announcements -->
                <article class="emp-home-widget emp-home-widget-wide" id="widget-announcements">
                    <div class="emp-home-widget-header">
                        <h3><i class="fa-solid fa-bullhorn" style="color:#f59e0b;"></i> Announcements</h3>
                    </div>
                    <div class="emp-home-widget-body" id="announcementsFeed">
                        {{#if overview.announcements.length}}
                            {{#each overview.announcements}}
                            <div class="emp-feed-item">
                                <div class="emp-feed-icon" style="background: rgba(14,165,233,0.12); color: var(--emp-primary);">
                                    <i class="fa-solid fa-{{#if (eq this.type 'salary')}}money-bill{{else}}{{#if (eq this.type 'team')}}users{{else}}info-circle{{/if}}{{/if}}"></i>
                                </div>
                                <div>
                                    <div class="fw-bold" style="font-size:14px;">{{this.title}}</div>
                                    <div class="text-muted" style="font-size:13px;">{{this.body}}</div>
                                </div>
                            </div>
                            {{/each}}
                        {{else}}
                        <div class="emp-widget-empty">
                            <i class="fa-solid fa-bullhorn"></i>
                            <p>No announcements right now</p>
                        </div>
                        {{/if}}
                    </div>
                </article>
            </div>
        </div>
    </div>
</div>

<script src="/assets/js/employee-dashboard.js"></script>
