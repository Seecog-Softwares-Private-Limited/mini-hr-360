<div class="container-fluid">
  <div class="row">
    {{> employee-sidebar employee=employee active=active portalNav=portalNav portalAccess=portalAccess portalRole=portalRole}}

    <div class="col-md-10 emp-main">
      <div class="emp-page-header mb-4">
        <h4 class="mb-1"><i class="fa-solid fa-chart-column me-2"></i>Team Reports</h4>
        <p class="text-muted mb-0">Summary metrics for your direct reports.</p>
      </div>

      <div class="row g-3">
        <div class="col-md-6">
          <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
              <h6 class="text-muted mb-3">This month</h6>
              <ul class="list-unstyled mb-0">
                <li class="d-flex justify-content-between py-2 border-bottom"><span>Team size</span><strong>{{teamSize}}</strong></li>
                <li class="d-flex justify-content-between py-2 border-bottom"><span>Present today</span><strong class="text-success">{{stats.presentToday}}</strong></li>
                <li class="d-flex justify-content-between py-2 border-bottom"><span>Absent / on leave today</span><strong class="text-danger">{{stats.absentToday}}</strong></li>
                <li class="d-flex justify-content-between py-2"><span>Pending leave requests</span><strong class="text-warning">{{stats.pendingLeave}}</strong></li>
              </ul>
            </div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
              <h6 class="text-muted mb-3">Approvals queue</h6>
              <p class="mb-3">Items waiting for your review as reporting manager.</p>
              <div class="d-grid gap-2">
                <a href="/employee/team/leaves" class="btn btn-outline-primary text-start">
                  Leave requests <span class="badge bg-warning text-dark ms-2">{{stats.pendingLeave}}</span>
                </a>
                <a href="/employee/team/corrections" class="btn btn-outline-primary text-start">
                  Attendance corrections <span class="badge bg-info ms-2">{{stats.pendingCorrections}}</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
