<div class="container-fluid">
  <div class="row">
    {{> employee-sidebar employee=employee active=active portalNav=portalNav portalAccess=portalAccess portalRole=portalRole}}

    <div class="col-md-10 emp-main">
      <div class="emp-page-header mb-4">
        <h4 class="mb-1"><i class="fa-solid fa-pen-to-square me-2"></i>Attendance Corrections</h4>
        <p class="text-muted mb-0">Review and approve attendance correction requests from your team.</p>
      </div>

      <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
          {{#if requests.length}}
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>Employee</th>
                  <th>Date</th>
                  <th>Type</th>
                  <th>Reason</th>
                  <th>Status</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody>
                {{#each requests}}
                <tr>
                  <td>
                    <div class="fw-600">{{employeeName}}</div>
                    <small class="text-muted">{{employeeId}}</small>
                  </td>
                  <td>{{date}}</td>
                  <td>{{type}}</td>
                  <td class="text-muted small">{{reason}}</td>
                  <td><span class="badge bg-warning text-dark">{{status}}</span></td>
                  <td class="text-end">
                    {{#if (eq status 'PENDING')}}
                    <button
                      type="button"
                      class="btn btn-sm btn-success me-1 team-corr-approve"
                      data-id="{{id}}"
                      data-employee-name="{{employeeName}}"
                      data-employee-id="{{employeeId}}"
                      data-date="{{date}}"
                      data-type="{{type}}"
                      data-reason="{{reason}}"
                    >Approve</button>
                    <button
                      type="button"
                      class="btn btn-sm btn-outline-danger team-corr-reject"
                      data-id="{{id}}"
                      data-employee-name="{{employeeName}}"
                      data-employee-id="{{employeeId}}"
                      data-date="{{date}}"
                      data-type="{{type}}"
                      data-reason="{{reason}}"
                    >Reject</button>
                    {{else}}—{{/if}}
                  </td>
                </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
          {{else}}
          <div class="p-5 text-center text-muted">No pending attendance corrections from your team.</div>
          {{/if}}
        </div>
      </div>
    </div>
  </div>
</div>

<script src="/assets/js/team-approve-modal.js"></script>
<script src="/assets/js/team-reject-modal.js"></script>
<script>
document.addEventListener('DOMContentLoaded', () => {
  function buildContextItems(btn) {
    return [
      { label: 'Employee', value: btn.dataset.employeeName || '—' },
      { label: 'Employee ID', value: btn.dataset.employeeId || '—' },
      { label: 'Date', value: btn.dataset.date || '—' },
      { label: 'Type', value: btn.dataset.type || '—' },
      { label: 'Reason', value: btn.dataset.reason || '—' },
    ];
  }

  async function submitAction(action, id, note) {
    const res = await fetch(`/employee/team/api/corrections/${id}/${action}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'include',
      body: JSON.stringify({ note: note || null }),
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || data.message || 'Action failed');
    window.location.reload();
  }

  document.querySelectorAll('.team-corr-approve').forEach((btn) => {
    btn.addEventListener('click', () => {
      openTeamApproveModal({
        title: 'Approve correction request',
        subtitle: 'The employee will be notified once you confirm this approval.',
        confirmLabel: 'Approve correction',
        contextItems: buildContextItems(btn),
        quickNotes: [
          'Approved — attendance record will be updated',
          'Please ensure supporting details are accurate',
        ],
        onConfirm: async (message) => {
          await submitAction('approve', btn.dataset.id, message);
        },
      });
    });
  });

  document.querySelectorAll('.team-corr-reject').forEach((btn) => {
    btn.addEventListener('click', () => {
      openTeamRejectModal({
        title: 'Reject correction request',
        subtitle: 'The employee will receive your message with this decision.',
        confirmLabel: 'Reject correction',
        contextItems: buildContextItems(btn),
        quickReasons: [
          'Insufficient supporting details',
          'Correction window has expired',
          'Please attach valid proof and resubmit',
          'Duplicate or conflicting entry',
        ],
        onConfirm: async (message) => {
          await submitAction('reject', btn.dataset.id, message);
        },
      });
    });
  });
});
</script>
