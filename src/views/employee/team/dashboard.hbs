<div class="container-fluid">
  <div class="row">
    {{> employee-sidebar employee=employee active=active portalNav=portalNav portalAccess=portalAccess portalRole=portalRole}}

    <div class="col-md-10 emp-main">
      <div class="emp-page-header mb-4">
        <h4 class="mb-1"><i class="fa-solid fa-chart-pie me-2"></i>Team Dashboard</h4>
        <p class="text-muted mb-0">Overview of your direct reports — attendance, leave, and pending approvals.</p>
      </div>

      <div class="row g-3 mb-4">
        <div class="col-md-3">
          <div class="emp-stat-card">
            <div class="emp-stat-label">Team size</div>
            <div class="emp-stat-value">{{stats.teamSize}}</div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="emp-stat-card">
            <div class="emp-stat-label">Present today</div>
            <div class="emp-stat-value text-success">{{stats.presentToday}}</div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="emp-stat-card">
            <div class="emp-stat-label">Pending leave</div>
            <div class="emp-stat-value text-warning">{{stats.pendingLeave}}</div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="emp-stat-card">
            <div class="emp-stat-label">Pending corrections</div>
            <div class="emp-stat-value text-info">{{stats.pendingCorrections}}</div>
          </div>
        </div>
      </div>

      <div class="row g-3">
        <div class="col-lg-7">
          <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0">
              <h6 class="mb-0">Direct reports</h6>
            </div>
            <div class="card-body p-0">
              {{#if team.length}}
              <div class="table-responsive">
                <table class="table table-hover mb-0">
                  <thead class="table-light">
                    <tr>
                      <th>Employee</th>
                      <th>Department</th>
                      <th>Designation</th>
                    </tr>
                  </thead>
                  <tbody>
                    {{#each team}}
                    <tr>
                      <td>
                        <div class="fw-600">{{empName}}</div>
                        <small class="text-muted">{{empId}}</small>
                      </td>
                      <td>{{empDepartment}}</td>
                      <td>{{empDesignation}}</td>
                    </tr>
                    {{/each}}
                  </tbody>
                </table>
              </div>
              {{else}}
              <div class="p-4 text-center text-muted">No employees are assigned to report to you yet.</div>
              {{/if}}
            </div>
          </div>
        </div>
        <div class="col-lg-5">
          <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0">
              <h6 class="mb-0">Quick actions</h6>
            </div>
            <div class="card-body d-grid gap-2">
              <a href="/employee/team/leaves" class="btn btn-outline-primary text-start">
                <i class="fa-solid fa-calendar-check me-2"></i>Review leave requests
                {{#if stats.pendingLeave}}<span class="badge bg-warning text-dark ms-2">{{stats.pendingLeave}}</span>{{/if}}
              </a>
              <a href="/employee/team/corrections" class="btn btn-outline-primary text-start">
                <i class="fa-solid fa-pen-to-square me-2"></i>Review attendance corrections
                {{#if stats.pendingCorrections}}<span class="badge bg-info ms-2">{{stats.pendingCorrections}}</span>{{/if}}
              </a>
              <a href="/employee/team/attendance" class="btn btn-outline-secondary text-start">
                <i class="fa-solid fa-user-clock me-2"></i>Team attendance
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
