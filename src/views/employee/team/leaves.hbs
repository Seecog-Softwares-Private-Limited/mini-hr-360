<div class="container-fluid">
  <div class="row">
    {{> employee-sidebar employee=employee active=active portalNav=portalNav portalAccess=portalAccess portalRole=portalRole}}

    <div class="col-md-10 emp-main">
      <div class="emp-page-header mb-4">
        <h4 class="mb-1"><i class="fa-solid fa-calendar-check me-2"></i>Team Leave Requests</h4>
        <p class="text-muted mb-0">Approve or reject leave requests from employees who report directly to you.</p>
      </div>

      <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
          {{#if requests.length}}
          <div class="table-responsive">
            <table class="table table-hover mb-0" id="teamLeaveTable">
              <thead class="table-light">
                <tr>
                  <th>Employee</th>
                  <th>Leave type</th>
                  <th>Dates</th>
                  <th>Days</th>
                  <th>Reason</th>
                  <th>Status</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody>
                {{#each requests}}
                <tr data-id="{{id}}">
                  <td>
                    <div class="fw-600">{{employeeName}}</div>
                    <small class="text-muted">{{employeeId}}{{#if department}} · {{department}}{{/if}}</small>
                  </td>
                  <td><span class="badge" style="background:{{leaveTypeColor}}">{{leaveType}}</span></td>
                  <td>{{startDate}} – {{endDate}}</td>
                  <td>{{totalDays}}</td>
                  <td class="text-muted small">{{reason}}</td>
                  <td><span class="badge bg-warning text-dark">{{status}}</span></td>
                  <td class="text-end">
                    {{#if (eq status 'PENDING')}}
                    <button
                      type="button"
                      class="btn btn-sm btn-success me-1 team-leave-approve"
                      data-id="{{id}}"
                      data-employee-name="{{employeeName}}"
                      data-employee-id="{{employeeId}}"
                      data-department="{{department}}"
                      data-leave-type="{{leaveType}}"
                      data-dates="{{startDate}} – {{endDate}}"
                      data-days="{{totalDays}}"
                      data-reason="{{reason}}"
                    >Approve</button>
                    <button
                      type="button"
                      class="btn btn-sm btn-outline-danger team-leave-reject"
                      data-id="{{id}}"
                      data-employee-name="{{employeeName}}"
                      data-employee-id="{{employeeId}}"
                      data-department="{{department}}"
                      data-leave-type="{{leaveType}}"
                      data-dates="{{startDate}} – {{endDate}}"
                      data-days="{{totalDays}}"
                      data-reason="{{reason}}"
                    >Reject</button>
                    {{else}}
                    <span class="text-muted small">—</span>
                    {{/if}}
                  </td>
                </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
          {{else}}
          <div class="p-5 text-center text-muted">
            <i class="fa-solid fa-inbox fa-2x mb-3 opacity-50"></i>
            <p class="mb-0">No pending leave requests from your team.</p>
          </div>
          {{/if}}
        </div>
      </div>
    </div>
  </div>
</div>

<script src="/assets/js/team-approve-modal.js"></script>
<script src="/assets/js/team-reject-modal.js"></script>
<script>
document.addEventListener('DOMContentLoaded', () => {
  function buildContextItems(btn) {
    const contextItems = [
      { label: 'Employee', value: btn.dataset.employeeName || '—' },
      { label: 'Employee ID', value: btn.dataset.employeeId || '—' },
      { label: 'Leave type', value: btn.dataset.leaveType || '—' },
      { label: 'Dates', value: btn.dataset.dates || '—' },
      { label: 'Days', value: btn.dataset.days || '—' },
    ];
    if (btn.dataset.department) {
      contextItems.splice(2, 0, { label: 'Department', value: btn.dataset.department });
    }
    if (btn.dataset.reason) {
      contextItems.push({ label: 'Employee reason', value: btn.dataset.reason });
    }
    return contextItems;
  }

  async function submitAction(action, id, comments) {
    const res = await fetch(`/employee/team/api/leaves/${id}/${action}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'include',
      body: JSON.stringify({ comments: comments || null }),
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || data.message || 'Action failed');
    window.location.reload();
  }

  document.querySelectorAll('.team-leave-approve').forEach((btn) => {
    btn.addEventListener('click', () => {
      openTeamApproveModal({
        title: 'Approve leave request',
        subtitle: 'The employee will be notified once you confirm this approval.',
        confirmLabel: 'Approve leave',
        contextItems: buildContextItems(btn),
        quickNotes: [
          'Approved — enjoy your time off',
          'Please ensure handover is complete before leave',
          'Keep your phone reachable for urgent matters',
          'Approved — coordinate with the team on coverage',
        ],
        onConfirm: async (message) => {
          await submitAction('approve', btn.dataset.id, message);
        },
      });
    });
  });

  document.querySelectorAll('.team-leave-reject').forEach((btn) => {
    btn.addEventListener('click', () => {
      openTeamRejectModal({
        title: 'Reject leave request',
        subtitle: 'The employee will receive your message with this decision.',
        confirmLabel: 'Reject leave',
        contextItems: buildContextItems(btn),
        quickReasons: [
          'Insufficient leave balance',
          'Critical project deadline',
          'Team coverage required during this period',
          'Please resubmit with revised dates',
          'Supporting documents required',
        ],
        onConfirm: async (message) => {
          await submitAction('reject', btn.dataset.id, message);
        },
      });
    });
  });
});
</script>
