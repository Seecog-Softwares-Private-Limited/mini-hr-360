<div class="container-fluid">
  <div class="row">
    {{> employee-sidebar employee=employee active=active portalNav=portalNav portalAccess=portalAccess portalRole=portalRole}}

    <div class="col-md-10 emp-main d-flex align-items-center justify-content-center" style="min-height:70vh;">
      <div class="text-center" style="max-width:480px;">
        <div class="mb-4">
          <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-danger bg-opacity-10 text-danger" style="width:80px;height:80px;">
            <i class="fa-solid fa-shield-halved fa-2x"></i>
          </span>
        </div>
        <h4 class="mb-2">Access denied</h4>
        <p class="text-muted mb-4">
          You don't have permission to view this page.
          {{#if employeeDisplayRole}}Your current role is <strong>{{employeeDisplayRole}}</strong>.{{/if}}
        </p>
        <a href="/employee/dashboard" class="btn btn-primary">
          <i class="fa-solid fa-house me-2"></i>Back to dashboard
        </a>
      </div>
    </div>
  </div>
</div>
