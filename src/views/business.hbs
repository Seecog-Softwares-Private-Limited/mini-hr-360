<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteBusinessModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete Organization</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this organization? This action cannot be undone.</p>
                <div class="alert alert-warning">
                    <strong>Organization:</strong> <span id="deleteBusinessName"></span><br>
                    <strong>Category:</strong> <span id="deleteBusinessCategory"></span>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" onclick="confirmDeleteBusiness()">Delete Organization</button>
            </div>
        </div>
    </div>
</div>

<script>
    let businesses = [];
    let capabilities = {};
    let currentDeleteId = null;

    function escapeHtml(text) {
        if (!text) return '';
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    function setActionButtonVisible(el, visible) {
        if (!el) return;
        el.classList.toggle('d-none', !visible);
        el.classList.toggle('d-inline-flex', visible);
    }

    function updateActionButtons() {
        const actions = document.getElementById('organizationActions');
        const addBtn = document.getElementById('addOrganizationBtn');
        const joinBtn = document.getElementById('joinOrganizationBtn');
        const manageRolesBtn = document.getElementById('manageRolesBtn');
        const setupWizardBtn = document.getElementById('setupWizardBtn');
        const hint = document.getElementById('organizationHint');
        const orgDashboard = document.getElementById('cpOrgDashboard');
        const orgListSection = document.getElementById('cpOrgListSection');

        const hasOrg = capabilities.hasOrganization === true
            || (Array.isArray(businesses) && businesses.length > 0);
        const canCreate = !hasOrg && !!capabilities.canCreate;
        const canJoin = !hasOrg && !!capabilities.canJoin;
        const multiOrg = (businesses || []).length > 1;

        const showActions = hasOrg || canCreate || canJoin;
        if (actions) {
            actions.classList.toggle('d-none', !showActions);
            actions.classList.toggle('d-flex', showActions);
        }
        setActionButtonVisible(manageRolesBtn, hasOrg);
        setActionButtonVisible(setupWizardBtn, hasOrg);
        setActionButtonVisible(addBtn, canCreate);
        setActionButtonVisible(joinBtn, canJoin);

        if (orgDashboard) orgDashboard.classList.toggle('d-none', !hasOrg);
        if (orgListSection) {
            orgListSection.classList.toggle('collapsed', hasOrg && !multiOrg);
        }

        if (hint) {
            if (hasOrg) {
                hint.classList.add('d-none');
            } else if (canCreate) {
                hint.classList.remove('d-none');
                hint.textContent = 'You can create one basic organization.';
            } else if (canJoin) {
                hint.classList.remove('d-none');
                hint.textContent = 'You can join one organization using an invite code from the owner.';
            } else {
                hint.classList.remove('d-none');
                hint.textContent = 'Only one organization link is allowed per account.';
            }
        }
    }

    function renderCompanyHero(business, details) {
        if (!business) return;
        const title = details?.displayName || details?.legalName || business.businessName || 'Organization';
        document.getElementById('cpHeroTitle').textContent = title;
        const subParts = [
            details?.registeredAddress || business.primaryAddress?.fullAddress,
            [details?.city || business.city, details?.state || business.state, details?.pincode || business.pincode].filter(Boolean).join(', '),
        ].filter(Boolean);
        document.getElementById('cpHeroSub').textContent = subParts[0] || business.description || 'No address on file';

        const chips = [];
        if (business.category) chips.push(`<span class="cp-chip primary"><i class="fas fa-industry"></i> ${escapeHtml(business.category)}</span>`);
        if (details?.panNumber) chips.push(`<span class="cp-chip success"><i class="fas fa-id-card"></i> PAN ${escapeHtml(details.panNumber)}</span>`);
        if (details?.gstNumber) chips.push(`<span class="cp-chip"><i class="fas fa-receipt"></i> GST ${escapeHtml(details.gstNumber)}</span>`);
        if (business.timezone) chips.push(`<span class="cp-chip"><i class="fas fa-clock"></i> ${escapeHtml(business.timezone)}</span>`);
        if (business.membershipType === 'owner') chips.push('<span class="cp-chip success"><i class="fas fa-crown"></i> Owner</span>');
        document.getElementById('cpHeroChips').innerHTML = chips.join('');

        const logoWrap = document.getElementById('cpLogoWrap');
        if (details?.logoUrl) {
            logoWrap.innerHTML = `<img src="${escapeHtml(details.logoUrl)}" alt="Logo">`;
        } else {
            logoWrap.innerHTML = '<i class="fas fa-building"></i>';
        }

        const branchCount = document.getElementById('branchesProfileList')?.querySelectorAll('.cp-branch-card').length || 0;
        document.getElementById('cpHeroStats').innerHTML = `
          <div class="cp-mini-stat"><div class="val">${escapeHtml(business.country || '—')}</div><div class="lbl">Country</div></div>
          <div class="cp-mini-stat"><div class="val">${branchCount || '—'}</div><div class="lbl">Branches</div></div>
          <div class="cp-mini-stat"><div class="val">${business.createdAt ? new Date(business.createdAt).getFullYear() : '—'}</div><div class="lbl">Since</div></div>`;

        const editBtn = document.getElementById('cpEditOrgBtn');
        if (editBtn) {
            editBtn.onclick = (e) => {
                e.preventDefault();
                if (business.membershipType === 'owner' || business.membershipType === 'admin') {
                    editBusiness(business.id);
                } else {
                    showAlert('Only organization owners can edit the profile.', 'warning');
                }
            };
        }
    }

    function updateSetupRing(score) {
        const ring = document.getElementById('setupProfileRing');
        const pct = document.getElementById('setupProfilePercent');
        if (!ring || !pct) return;
        const circumference = 251.2;
        const offset = circumference - (circumference * Math.min(100, score)) / 100;
        ring.style.strokeDashoffset = String(offset);
        pct.textContent = Math.round(score);
    }

    async function loadBusinesses() {
        try {
            const data = await apiCall('/business');
            businesses = Array.isArray(data?.organizations) ? data.organizations : (Array.isArray(data) ? data : (data?.data?.organizations || data?.data || []));
            capabilities = data?.capabilities || {};
            if (businesses.length > 0) {
                capabilities.hasOrganization = true;
                capabilities.canCreate = false;
                capabilities.canJoin = false;
            }
            updateActionButtons();
            displayBusinesses(businesses);

            const preferred = businesses.find((b) => b.membershipType === 'owner') || businesses[0];
            if (preferred?.id && typeof window.getOrganizationId === 'function' && !window.getOrganizationId()) {
                const id = String(preferred.id);
                localStorage.setItem('mh360:organizationId', id);
                document.cookie = `mh360_organization_id=${encodeURIComponent(id)}; path=/; max-age=${30 * 24 * 60 * 60}; samesite=lax`;
                document.cookie = `mh360_workspace_id=${encodeURIComponent(id)}; path=/; max-age=${30 * 24 * 60 * 60}; samesite=lax`;
            }
            await loadSetupProfile();
        } catch (error) {
            console.error('Error loading organizations:', error);
            document.getElementById('businessesGrid').innerHTML =
                '<div class="col-12 text-center text-danger py-4">Error loading organizations</div>';
        }
    }

    function displayBusinesses(businessesToShow) {
        const grid = document.getElementById('businessesGrid');

        if (!Array.isArray(businessesToShow) || businessesToShow.length === 0) {
            const emptyMsg = capabilities.canJoin
                ? 'No organizations yet. Use Join Organization with an invite code.'
                : capabilities.canCreate
                    ? 'No organizations yet. Create your organization to get started.'
                    : 'No organizations found.';
            grid.innerHTML = `<div class="col-12 text-center text-muted py-4">${emptyMsg}</div>`;
            return;
        }

        grid.innerHTML = businessesToShow.map(business => {
            const isOwner = business.membershipType === 'owner' || business.membershipType === 'admin';
            const membershipBadge = business.membershipType === 'member'
                ? '<span class="badge bg-secondary ms-2">Member</span>'
                : business.membershipType === 'owner'
                    ? '<span class="badge bg-success ms-2">Owner</span>'
                    : '';
            const inviteBlock = isOwner && business.inviteCode
                ? `<div class="mt-2"><small class="text-muted">Invite code:</small> <code>${escapeHtml(business.inviteCode)}</code></div>`
                : '';

            return `
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h5 class="card-title mb-0">${escapeHtml(business.businessName || 'Untitled')}${membershipBadge}</h5>
                            ${isOwner ? `
                            <div class="dropdown">
                                <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-ellipsis-v"></i>
                                </button>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="#" onclick="editBusiness(${business.id}); return false;">
                                        <i class="fas fa-edit me-2"></i>Edit
                                    </a></li>
                                    <li><a class="dropdown-item text-danger" href="#" onclick="deleteBusiness(${business.id}, '${escapeHtml(business.businessName || '')}', '${escapeHtml(business.category || '')}'); return false;">
                                        <i class="fas fa-trash me-2"></i>Delete
                                    </a></li>
                                </ul>
                            </div>` : ''}
                        </div>
                        <div class="mb-2">
                            <span class="badge bg-primary">${escapeHtml(business.category || 'No Category')}</span>
                        </div>
                        <p class="card-text text-muted small">${escapeHtml(business.description || 'No description provided')}</p>
                        ${inviteBlock}
                        <div class="row text-center">
                            <div class="col-6">
                                <small class="text-muted">Phone</small><br>
                                <small>${escapeHtml(business.phoneNo || 'Not provided')}</small>
                            </div>
                            <div class="col-6">
                                <small class="text-muted">WhatsApp</small><br>
                                <small>${escapeHtml(business.whatsappNo || 'Not provided')}</small>
                            </div>
                        </div>
                        <div class="mt-3">
                            <small class="text-muted">
                                <i class="fas fa-map-marker-alt me-1"></i>
                                ${escapeHtml(business.country || 'No country')} • ${escapeHtml(business.timezone || 'No timezone')}
                            </small>
                        </div>
                        ${business.primaryAddress?.fullAddress ? `
                        <div class="mt-2">
                            <small class="text-muted">
                                <strong>${escapeHtml(business.primaryAddress.addressName || 'Address')}:</strong>
                                ${escapeHtml(business.primaryAddress.fullAddress)}
                            </small>
                        </div>` : ''}
                    </div>
                    <div class="card-footer bg-transparent">
                        <div class="d-flex justify-content-between align-items-center">
                            <small class="text-muted">
                                Created: ${business.createdAt ? new Date(business.createdAt).toLocaleDateString() : '—'}
                            </small>
                            <button class="btn btn-sm btn-outline-primary" type="button" onclick="openOrganizationOverview(${business.id})">
                                Open Overview
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        `;
        }).join('');
    }

    function searchBusinesses() {
        const searchTerm = document.getElementById('searchInput').value.toLowerCase().trim();
        const filtered = (businesses || []).filter(b =>
            (b.businessName || '').toLowerCase().includes(searchTerm) ||
            (b.description || '').toLowerCase().includes(searchTerm) ||
            (b.category || '').toLowerCase().includes(searchTerm)
        );
        displayBusinesses(filtered);
    }

    function filterByCategory() {
        const selectedCategory = document.getElementById('categoryFilter').value;
        const searchTerm = document.getElementById('searchInput').value.toLowerCase().trim();

        let filtered = businesses || [];
        if (selectedCategory) filtered = filtered.filter(b => (b.category || '') === selectedCategory);
        if (searchTerm) {
            filtered = filtered.filter(b =>
                (b.businessName || '').toLowerCase().includes(searchTerm) ||
                (b.description || '').toLowerCase().includes(searchTerm) ||
                (b.category || '').toLowerCase().includes(searchTerm)
            );
        }
        displayBusinesses(filtered);
    }

    function clearFilters() {
        document.getElementById('searchInput').value = '';
        document.getElementById('categoryFilter').value = '';
        displayBusinesses(businesses);
    }

    function openOrganizationOverview(organizationId) {
        if (!organizationId) return;
        const id = String(organizationId);
        localStorage.setItem('mh360:organizationId', id);
        localStorage.setItem('mh360:workspaceId', id);
        document.cookie = `mh360_organization_id=${encodeURIComponent(id)}; path=/; max-age=${30 * 24 * 60 * 60}; samesite=lax`;
        document.cookie = `mh360_workspace_id=${encodeURIComponent(id)}; path=/; max-age=${30 * 24 * 60 * 60}; samesite=lax`;
        window.location.href = '/dashboard';
    }

    function normPhone(value) {
        if (!value) return '';
        const digits = String(value).replace(/\D/g, '');
        if (!digits) return '';
        if (digits.length === 12 && digits.startsWith('91')) return '+'.concat(digits);
        if (digits.length === 10) return '+91' + digits;
        return '+' + digits;
    }

    async function addBusiness() {
        const form = document.getElementById('addBusinessForm');
        const formData = new FormData(form);

        const businessData = {
            businessName: formData.get('businessName')?.trim(),
            category: formData.get('category'),
            description: formData.get('description')?.trim(),
            phoneNo: normPhone(formData.get('phoneNo')),
            whatsappNo: normPhone(formData.get('whatsappNo')),
            country: formData.get('country'),
            timezone: formData.get('timezone'),
            addressName: formData.get('addressName')?.trim(),
            fullAddress: formData.get('fullAddress')?.trim()
        };

        try {
            const data = await apiCall('/business', {
                method: 'POST',
                body: JSON.stringify(businessData)
            });

            if (data && !data.error) {
                bootstrap.Modal.getInstance(document.getElementById('addBusinessModal'))?.hide();
                form.reset();
                loadBusinesses();
                showAlert('Organization created successfully!', 'success');
            } else {
                showAlert((data && (data.message || data.error)) || 'Failed to create organization', 'danger');
            }
        } catch (error) {
            showAlert(error?.message || 'Network error. Please try again.', 'danger');
        }
    }

    async function joinOrganization(event) {
        event.preventDefault();
        const inviteCode = document.getElementById('inviteCode')?.value?.trim().toUpperCase();
        const alertEl = document.getElementById('joinOrganizationAlert');
        const submitBtn = document.getElementById('joinOrganizationSubmitBtn');

        alertEl?.classList.add('d-none');
        submitBtn.disabled = true;

        try {
            const data = await apiCall('/business/join', {
                method: 'POST',
                body: JSON.stringify({ inviteCode }),
            });

            if (data && !data.error) {
                bootstrap.Modal.getInstance(document.getElementById('joinOrganizationModal'))?.hide();
                document.getElementById('joinOrganizationForm')?.reset();
                loadBusinesses();
                showAlert('Joined organization successfully!', 'success');
            } else {
                alertEl.textContent = data?.message || 'Failed to join organization';
                alertEl.classList.remove('d-none');
            }
        } catch (error) {
            alertEl.textContent = error?.message || 'Failed to join organization';
            alertEl.classList.remove('d-none');
        } finally {
            submitBtn.disabled = false;
        }
    }

    function editBusiness(businessId) {
        const business = (businesses || []).find(b => b.id === businessId);
        if (!business) return;

        document.getElementById('editBusinessId').value = business.id;
        document.getElementById('editBusinessName').value = business.businessName || '';
        document.getElementById('editCategory').value = business.category || '';
        document.getElementById('editDescription').value = business.description || '';
        document.getElementById('editAddressName').value = business.primaryAddress?.addressName || '';
        document.getElementById('editFullAddress').value = business.primaryAddress?.fullAddress || '';
        document.getElementById('editCountry').value = business.country || '';
        document.getElementById('editTimezone').value = business.timezone || 'Asia/Kolkata';

        const strip91 = v => (v || '').replace(/^\+91/, '');
        document.getElementById('editPhoneNo').value = strip91(business.phoneNo);
        document.getElementById('editWhatsappNo').value = strip91(business.whatsappNo);

        new bootstrap.Modal(document.getElementById('editBusinessModal')).show();
    }

    async function updateBusiness() {
        const form = document.getElementById('editBusinessForm');
        const formData = new FormData(form);

        const businessData = {
            businessName: formData.get('businessName')?.trim(),
            category: formData.get('category'),
            description: formData.get('description')?.trim(),
            phoneNo: normPhone(formData.get('phoneNo')),
            whatsappNo: normPhone(formData.get('whatsappNo')),
            country: formData.get('country'),
            timezone: formData.get('timezone'),
            addressName: formData.get('addressName')?.trim(),
            fullAddress: formData.get('fullAddress')?.trim()
        };

        const businessId = formData.get('id');

        try {
            const data = await apiCall(`/business/${businessId}`, {
                method: 'PUT',
                body: JSON.stringify(businessData)
            });

            if (data && !data.error) {
                bootstrap.Modal.getInstance(document.getElementById('editBusinessModal'))?.hide();
                loadBusinesses();
                showAlert('Organization updated successfully!', 'success');
            } else {
                showAlert((data && (data.message || data.error)) || 'Failed to update organization', 'danger');
            }
        } catch (error) {
            showAlert('Network error. Please try again.', 'danger');
        }
    }

    function deleteBusiness(businessId, businessName, businessCategory) {
        currentDeleteId = businessId;
        document.getElementById('deleteBusinessName').textContent = businessName || '';
        document.getElementById('deleteBusinessCategory').textContent = businessCategory || '';
        new bootstrap.Modal(document.getElementById('deleteBusinessModal')).show();
    }

    async function confirmDeleteBusiness() {
        if (!currentDeleteId) return;

        try {
            const data = await apiCall(`/business/${currentDeleteId}`, { method: 'DELETE' });

            if (data === undefined || (data && !data.error)) {
                bootstrap.Modal.getInstance(document.getElementById('deleteBusinessModal'))?.hide();
                loadBusinesses();
                showAlert('Organization deleted successfully!', 'success');
            } else {
                showAlert((data.message || data.error) || 'Failed to delete organization', 'danger');
            }
        } catch (error) {
            showAlert(error?.message || 'Failed to delete organization', 'danger');
        } finally {
            currentDeleteId = null;
        }
    }

    function showAlert(message, type) {
        const alertDiv = document.createElement('div');
        alertDiv.className = `alert alert-${type} alert-dismissible fade show position-fixed`;
        alertDiv.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
        alertDiv.innerHTML = `
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;
        document.body.appendChild(alertDiv);
        setTimeout(() => { alertDiv.remove(); }, 5000);
    }

    async function loadSetupProfile() {
        try {
            const token = localStorage.getItem('accessToken');
            const headers = { 'Content-Type': 'application/json' };
            if (token) headers.Authorization = `Bearer ${token}`;
            const orgId = typeof getOrganizationId === 'function' ? getOrganizationId() : localStorage.getItem('mh360:organizationId');
            if (!orgId) return;
            headers['x-business-id'] = orgId;

            const activeBusiness = (businesses || []).find((b) => String(b.id) === String(orgId))
                || (businesses || []).find((b) => b.membershipType === 'owner')
                || (businesses || [])[0];

            const [statusRes, branchesRes, detailsRes] = await Promise.all([
                fetch('/api/setup/status', { credentials: 'include', headers }),
                fetch('/api/setup/branches', { credentials: 'include', headers }),
                fetch('/api/setup/company-details', { credentials: 'include', headers }),
            ]);

            let details = null;
            if (detailsRes.ok) {
                const dJson = await detailsRes.json();
                details = dJson.data ?? dJson;
            }
            if (activeBusiness) renderCompanyHero(activeBusiness, details);

            if (!statusRes.ok) return;
            const statusJson = await statusRes.json();
            const status = statusJson.data ?? statusJson;
            const score = status.score || 0;

            updateSetupRing(score);
            document.getElementById('setupProfileScore').textContent = score >= 100
                ? 'Setup complete — your organization is ready'
                : `Company setup is ${score}% complete`;
            document.getElementById('setupProfileHint').textContent = status.setupCompleted
                ? 'All core onboarding steps are done. Review anytime.'
                : 'Complete onboarding to unlock payroll readiness.';

            const stepsEl = document.getElementById('setupProfileSteps');
            if (stepsEl && status.steps) {
                stepsEl.innerHTML = status.steps.map((s) =>
                    `<span class="cp-step-pill ${s.completed ? 'done' : ''}">${escapeHtml(s.title)}</span>`
                ).join('');
            }

            const missing = (status.missingItems || []).filter((m) => m.severity !== 'info').slice(0, 4);
            const missingEl = document.getElementById('setupProfileMissing');
            if (missingEl) {
                if (!missing.length) {
                    missingEl.className = 'cp-missing-list success';
                    missingEl.innerHTML = '<i class="fas fa-check-circle me-1"></i> All key items configured';
                } else {
                    missingEl.className = 'cp-missing-list';
                    missingEl.innerHTML = `<strong>Needs attention</strong><ul>${missing.map((m) => `<li>${escapeHtml(m.message)}</li>`).join('')}</ul>`;
                }
            }

            const setupBtn = document.getElementById('setupProfileBtn');
            if (setupBtn) {
                setupBtn.textContent = status.setupCompleted || score >= 100 ? 'Review Setup' : 'Continue Setup';
            }

            if (branchesRes.ok) {
                const bJson = await branchesRes.json();
                const branches = (bJson.data ?? bJson).branches || [];
                if (branches.length) {
                    document.getElementById('branchesProfileSection')?.classList.remove('d-none');
                    document.getElementById('branchesProfileList').innerHTML = branches.map((b) =>
                        `<div class="cp-branch-card ${b.isPrimary ? 'primary' : ''}">
                          <div class="cp-branch-name">
                            ${escapeHtml(b.name)}
                            ${b.isPrimary ? '<span class="badge bg-primary ms-1" style="font-size:9px">Primary</span>' : ''}
                          </div>
                          <div class="cp-branch-loc">
                            <i class="fas fa-location-dot"></i>
                            ${escapeHtml([b.city, b.state, b.pincode].filter(Boolean).join(', ') || b.address || 'No address')}
                          </div>
                          ${b.code ? `<div class="cp-branch-loc mt-1"><i class="fas fa-barcode"></i> ${escapeHtml(b.code)}</div>` : ''}
                        </div>`
                    ).join('');
                }
            }

            if (activeBusiness) renderCompanyHero(activeBusiness, details);
        } catch (e) { console.warn('Setup profile load failed', e); }
    }

    document.addEventListener('DOMContentLoaded', () => { loadBusinesses(); });
    document.getElementById('searchInput').addEventListener('input', searchBusinesses);
</script>
