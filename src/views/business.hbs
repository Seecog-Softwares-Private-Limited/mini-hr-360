<link href="/assets/css/company-setup.css" rel="stylesheet">
<link href="/assets/css/company-profile.css" rel="stylesheet">

<div class="cp-page">
  <div class="cp-header">
    <div>
      <div class="page-title" style="font-size: 28px;">Company Profile</div>
      <div class="page-subtitle">Organization identity, setup health, and branch network</div>
    </div>
    <div class="cp-header-actions d-none" id="organizationActions">
      <a class="btn btn-outline-secondary d-none align-items-center gap-2" id="manageRolesBtn" href="/admin/team">
        <i class="fas fa-users-gear"></i> Manage Roles
      </a>
      <a class="btn btn-outline-primary d-none align-items-center gap-2" id="setupWizardBtn" href="/admin/setup">
        <i class="fas fa-wand-magic-sparkles"></i> Company Setup
      </a>
      <button class="btn btn-outline-primary d-none align-items-center gap-2" id="joinOrganizationBtn" data-bs-toggle="modal" data-bs-target="#joinOrganizationModal" type="button">
        <i class="fas fa-right-to-bracket"></i> Join Organization
      </button>
      <button class="btn btn-primary d-none align-items-center gap-2" id="addOrganizationBtn" data-bs-toggle="modal" data-bs-target="#addBusinessModal" type="button">
        <i class="fas fa-plus"></i> Add Organization
      </button>
    </div>
  </div>

  <div id="organizationHint" class="alert alert-info d-none mb-4"></div>

  <!-- Premium org dashboard (single active org) -->
  <div id="cpOrgDashboard" class="d-none">
    <div class="cp-hero" id="cpHero">
      <div class="cp-hero-inner">
        <div class="cp-logo-wrap" id="cpLogoWrap"><i class="fas fa-building"></i></div>
        <div class="cp-hero-meta">
          <h1 class="cp-hero-title" id="cpHeroTitle">—</h1>
          <p class="cp-hero-sub" id="cpHeroSub">Loading organization…</p>
          <div class="cp-chip-row" id="cpHeroChips"></div>
        </div>
      </div>
      <div class="cp-stat-row" id="cpHeroStats"></div>
    </div>

    <div class="cp-dashboard-grid">
      <div class="cp-main-col">
        <div class="cp-panel mb-3" id="setupProfileCard">
          <div class="cp-panel-head">
            <h5><i class="fas fa-chart-pie"></i> Setup Health</h5>
            <a href="/admin/setup" class="btn btn-primary btn-sm" id="setupProfileBtn">Continue Setup</a>
          </div>
          <div class="cp-panel-body">
            <div class="cp-setup-layout">
              <div class="cp-score-ring">
                <svg viewBox="0 0 96 96" aria-hidden="true">
                  <defs>
                    <linearGradient id="cpScoreGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                      <stop offset="0%" stop-color="#6366f1"/>
                      <stop offset="100%" stop-color="#22c55e"/>
                    </linearGradient>
                  </defs>
                  <circle class="ring-bg" cx="48" cy="48" r="40"/>
                  <circle class="ring-fill" id="setupProfileRing" cx="48" cy="48" r="40"
                    stroke-dasharray="251.2" stroke-dashoffset="251.2"/>
                </svg>
                <div class="cp-score-value">
                  <span id="setupProfilePercent">0</span>%
                  <small>complete</small>
                </div>
              </div>
              <div class="cp-setup-detail">
                <div class="cp-setup-status" id="setupProfileScore">Checking setup status…</div>
                <div class="cp-setup-hint" id="setupProfileHint">Complete onboarding to unlock payroll readiness.</div>
                <div class="cp-step-pills" id="setupProfileSteps"></div>
                <div class="cp-missing-list" id="setupProfileMissing"></div>
              </div>
            </div>
          </div>
        </div>

        <div class="cp-panel d-none" id="branchesProfileSection">
          <div class="cp-panel-head">
            <h5><i class="fas fa-map-location-dot"></i> Branches &amp; Locations</h5>
            <a href="/admin/setup" class="btn btn-outline-secondary btn-sm">Manage</a>
          </div>
          <div class="cp-panel-body">
            <div class="cp-branch-grid" id="branchesProfileList"></div>
          </div>
        </div>
      </div>

      <aside class="cp-side-col">
        <div class="cp-panel">
          <div class="cp-panel-head"><h5><i class="fas fa-bolt"></i> Quick Actions</h5></div>
          <div class="cp-panel-body pt-2 pb-2">
            <a href="/admin/setup" class="cp-quick-action">
              <i class="fas fa-wand-magic-sparkles"></i>
              <div><span>Company Setup</span><small>Finish onboarding wizard</small></div>
            </a>
            <a href="/admin/payroll/setup" class="cp-quick-action">
              <i class="fas fa-coins"></i>
              <div><span>Payroll Setup</span><small>Salary components &amp; statutory</small></div>
            </a>
            <a href="/admin/attendance/shifts" class="cp-quick-action">
              <i class="fas fa-clock"></i>
              <div><span>Attendance</span><small>Shifts, policies &amp; holidays</small></div>
            </a>
            <a href="#" class="cp-quick-action" id="cpEditOrgBtn">
              <i class="fas fa-pen-to-square"></i>
              <div><span>Edit Profile</span><small>Update organization details</small></div>
            </a>
          </div>
        </div>
      </aside>
    </div>
  </div>

  <div class="cp-org-list-section" id="cpOrgListSection">
    <div class="row mb-4">
      <div class="col-md-6">
        <div class="input-group">
          <input type="text" class="form-control" id="searchInput" placeholder="Search organizations...">
          <button class="btn btn-outline-secondary" type="button" onclick="searchBusinesses()">
            <i class="fas fa-search"></i>
          </button>
        </div>
      </div>
      <div class="col-md-3">
        <select class="form-select" id="categoryFilter" onchange="filterByCategory()">
          <option value="">All Categories</option>
          <option value="restaurant">Restaurant</option>
          <option value="retail">Retail</option>
          <option value="healthcare">Healthcare</option>
          <option value="education">Education</option>
          <option value="technology">Technology</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div class="col-md-3">
        <button class="btn btn-outline-secondary w-100" onclick="clearFilters()">
          <i class="fas fa-times me-2"></i>Clear Filters
        </button>
      </div>
    </div>

    <div class="row" id="businessesGrid">
      <div class="col-12 text-center py-4">
        <div class="spinner-border text-primary" role="status">
          <span class="visually-hidden">Loading...</span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Add Organization Modal -->
<div class="modal fade" id="addBusinessModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Organization</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="addBusinessForm">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="businessName" class="form-label">Organization Name *</label>
                            <input type="text" class="form-control" id="businessName" name="businessName" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="category" class="form-label">Category *</label>
                            <select class="form-select" id="category" name="category" required>
                                <option value="">Select Category</option>
                                <option value="restaurant">Restaurant</option>
                                <option value="retail">Retail</option>
                                <option value="healthcare">Healthcare</option>
                                <option value="education">Education</option>
                                <option value="technology">Technology</option>
                                <option value="other">Other</option>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="phoneNo" class="form-label">Phone Number</label>
                            <div class="input-group">
                                <span class="input-group-text">+91</span>
                                <input type="tel" class="form-control" id="phoneNo" name="phoneNo" placeholder="9999999999">
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="whatsappNo" class="form-label">WhatsApp Number</label>
                            <div class="input-group">
                                <span class="input-group-text">+91</span>
                                <input type="tel" class="form-control" id="whatsappNo" name="whatsappNo" placeholder="9999999999">
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="country" class="form-label">Country *</label>
                            <select class="form-select" id="country" name="country" required>
                                <option value="">Select Country</option>
                                <option value="IN">India</option>
                                <option value="US">United States</option>
                                <option value="UK">United Kingdom</option>
                                <option value="CA">Canada</option>
                                <option value="AU">Australia</option>
                                <option value="other">Other</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="timezone" class="form-label">Timezone</label>
                            <select class="form-select" id="timezone" name="timezone">
                                <option value="Asia/Kolkata">Asia/Kolkata (IST)</option>
                                <option value="America/New_York">America/New_York (EST)</option>
                                <option value="America/Los_Angeles">America/Los_Angeles (PST)</option>
                                <option value="Europe/London">Europe/London (GMT)</option>
                                <option value="Australia/Sydney">Australia/Sydney (AEST)</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="description" class="form-label">Description</label>
                        <textarea class="form-control" id="description" name="description" rows="3" placeholder="Brief description of your organization"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label for="addressName" class="form-label">Address Label</label>
                            <input type="text" class="form-control" id="addressName" name="addressName" placeholder="Head Office">
                        </div>
                        <div class="col-md-8 mb-3">
                            <label for="fullAddress" class="form-label">Organization Address</label>
                            <textarea class="form-control" id="fullAddress" name="fullAddress" rows="2" placeholder="Street, area, city, state, postal code"></textarea>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="addBusiness()">Add Organization</button>
            </div>
        </div>
    </div>
</div>

<!-- Join Organization Modal -->
