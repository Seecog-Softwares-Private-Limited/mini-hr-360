<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-4">
  <div>
    <div class="page-title" style="font-size: 28px;">Contract Workflow</div>
    <div class="page-subtitle" id="contractWizardSubtitle">{{employeeName}} ({{employeeCode}})</div>
  </div>
  <a href="/employees" class="btn btn-outline-secondary"><i class="fa-solid fa-arrow-left me-2"></i>Back to Employees</a>
</div>

<div class="section-card mb-4">
  <div class="p-3" id="contractStatusBar">Loading contract status…</div>
</div>

<div class="row g-4">
  <div class="col-lg-5">
    <div class="section-card h-100">
      <div class="section-header"><h5><i class="fa-solid fa-file-contract"></i> Renew contract</h5></div>
      <div class="p-3">
        <p class="small text-muted">Extend the contract end date and optionally revise CTC. Generate a new offer letter from Documents after renewal.</p>
        <form id="renewContractForm" class="row g-3">
          <div class="col-12">
            <label class="form-label">New contract end date *</label>
            <input type="date" name="contractEndDate" class="form-control" required />
          </div>
          <div class="col-12">
            <label class="form-label">Revised annual CTC (optional)</label>
            <input type="number" step="0.01" min="0" name="empCtc" class="form-control" id="renewCtcInput" />
          </div>
          <div class="col-12">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" name="syncPayroll" id="syncPayrollRenew" value="true" checked />
              <label class="form-check-label" for="syncPayrollRenew">Sync payroll structure if CTC changes</label>
            </div>
          </div>
          <div class="col-12">
            <button type="submit" class="btn btn-primary" id="btnRenewContract">
              <i class="fa-solid fa-rotate me-2"></i>Save renewal
            </button>
            <a href="#" class="btn btn-outline-primary ms-2" id="linkRenewOffer">Generate renewal offer</a>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="col-lg-7">
    <div class="section-card mb-4">
      <div class="section-header"><h5><i class="fa-solid fa-calendar-xmark"></i> Non-renewal / expiry exit</h5></div>
      <div class="p-3">
        <p class="small text-muted">Start offboarding when the contract will not be renewed. Resignation letter is skipped — last working day defaults to contract end.</p>
        <form id="nonRenewForm" class="row g-3">
          <div class="col-md-6">
            <label class="form-label">Last working day</label>
            <input type="date" name="lastWorkingDay" class="form-control" id="nonRenewLwd" />
          </div>
          <div class="col-md-6">
            <label class="form-label">Notice period (days)</label>
            <input type="number" min="0" name="noticePeriodDays" class="form-control" value="0" />
          </div>
          <div class="col-12">
            <label class="form-label">Reason</label>
            <textarea name="exitReason" class="form-control" rows="2">Contract not renewed — scheduled expiry</textarea>
          </div>
          <div class="col-12 d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-warning" id="btnNonRenew">
              <i class="fa-solid fa-door-open me-2"></i>Initiate expiry offboarding
            </button>
            <a href="#" class="btn btn-outline-warning" id="linkExitWizard">Open exit workflow</a>
          </div>
        </form>
      </div>
    </div>

    <div class="section-card">
      <div class="section-header"><h5><i class="fa-solid fa-clock-rotate-left"></i> Lifecycle timeline</h5></div>
      <div class="p-3" id="contractTimeline"><p class="text-muted mb-0">—</p></div>
    </div>
  </div>
</div>

<script>
(function () {
  const employeeId = {{employeeId}};
  let state = null;

  function renderStatus(s) {
    const bar = document.getElementById('contractStatusBar');
    const c = s.contract || {};
    const days = c.daysRemaining;
    let badge = 'bg-secondary';
    let label = 'No end date set';
    if (days != null) {
      if (days < 0) { badge = 'bg-danger'; label = `Expired ${Math.abs(days)} day(s) ago`; }
      else if (days <= 30) { badge = 'bg-warning text-dark'; label = `${days} day(s) remaining`; }
      else { badge = 'bg-success'; label = `${days} day(s) remaining`; }
    }
    bar.innerHTML = `
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
        <div>
          <div class="text-muted small">${s.employee?.employeeType || 'Contract'} · ${s.employee?.lifecycleStageLabel || ''}</div>
          <div class="fw-semibold">Contract ends: ${c.contractEndDate || '—'}</div>
        </div>
        <span class="badge ${badge}">${label}</span>
      </div>`;
  }

  function renderTimeline(events) {
    const el = document.getElementById('contractTimeline');
    if (!events?.length) {
      el.innerHTML = '<p class="text-muted">No lifecycle events yet.</p>';
      return;
    }
    el.innerHTML = events.slice(0, 8).map((e) => `
      <div class="small border-bottom pb-2 mb-2">
        <strong>${e.action}</strong> · ${e.fromStage || '—'} → ${e.toStage}
        <div class="text-muted">${new Date(e.createdAt).toLocaleString()}</div>
      </div>`).join('');
  }

  async function loadWizard() {
    const res = await fetch(`/api/v1/employees/${employeeId}/contract-wizard`);
    const body = await res.json().catch(() => ({}));
    if (!res.ok) return alert(body.error || 'Failed to load contract workflow');
    state = body;

    document.getElementById('contractWizardSubtitle').textContent =
      `${state.employee.empName} (${state.employee.empId}) — ${state.employee.lifecycleStageLabel}`;

    renderStatus(state);
    renderTimeline(state.events);

    const renewForm = document.getElementById('renewContractForm');
    if (state.contract?.contractEndDate) {
      renewForm.elements.contractEndDate.value = state.contract.contractEndDate;
    }
    if (state.employee?.empCtc) {
      document.getElementById('renewCtcInput').value = state.employee.empCtc;
    }
    if (state.contract?.contractEndDate) {
      document.getElementById('nonRenewLwd').value = state.contract.contractEndDate;
    }

    document.getElementById('linkRenewOffer').href = `/documents?employeeId=${employeeId}`;
    document.getElementById('linkExitWizard').href = `/exit-workflow/${employeeId}`;
  }

  document.getElementById('renewContractForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(e.target);
    const res = await fetch(`/api/v1/employees/${employeeId}/contract-wizard/renew`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        contractEndDate: fd.get('contractEndDate'),
        empCtc: fd.get('empCtc') || undefined,
        syncPayroll: fd.get('syncPayroll') === 'true',
      }),
    });
    const body = await res.json().catch(() => ({}));
    if (!res.ok) return alert(body.error || 'Renewal failed');
    alert('Contract renewed successfully');
    await loadWizard();
  });

  document.getElementById('nonRenewForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!confirm('Start offboarding for contract non-renewal?')) return;
    const data = Object.fromEntries(new FormData(e.target).entries());
    const res = await fetch(`/api/v1/employees/${employeeId}/contract-wizard/non-renew`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    });
    const body = await res.json().catch(() => ({}));
    if (!res.ok) return alert(body.error || 'Failed to initiate exit');
    alert('Offboarding started — open Exit Workflow to complete documents.');
    window.location.href = `/exit-workflow/${employeeId}`;
  });

  loadWizard();
})();
</script>
