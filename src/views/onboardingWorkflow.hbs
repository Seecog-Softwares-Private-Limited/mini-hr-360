<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-4">
  <div>
    <div class="page-title" style="font-size: 28px;">Onboarding Workflow</div>
    <div class="page-subtitle" id="onboardingWizardSubtitle">{{employeeName}} ({{employeeCode}})</div>
  </div>
  <a href="/employees" class="btn btn-outline-secondary"><i class="fa-solid fa-arrow-left me-2"></i>Back to Employees</a>
</div>

<div class="section-card mb-4">
  <div class="p-3">
    <div class="d-flex flex-wrap gap-2 mb-3" id="onboardingStageBadges"></div>
    <div id="onboardingReadinessBar" class="small text-muted mb-0">Loading workflow…</div>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-5">
    <div class="section-card h-100">
      <div class="section-header"><h5><i class="fa-solid fa-user-check"></i> Stage &amp; profile</h5></div>
      <div class="p-3">
        <p class="small text-muted">Advance lifecycle stage manually when HR steps are complete outside document generation.</p>
        <form id="onboardingStageForm" class="row g-3">
          <div class="col-12">
            <label class="form-label">Lifecycle stage</label>
            <select name="stage" class="form-select" id="onboardingStageSelect">
              <option value="prospect">Prospect</option>
              <option value="offer">Offer</option>
              <option value="joining">Joining</option>
              <option value="active">Active</option>
              <option value="confirmed">Confirmed</option>
            </select>
          </div>
          <div class="col-12">
            <button type="submit" class="btn btn-primary">
              <i class="fa-solid fa-forward me-2"></i>Update stage
            </button>
          </div>
        </form>
        <hr />
        <div id="onboardingQuickActions" class="d-flex flex-wrap gap-2 mb-3"></div>
        <a href="/employees" class="btn btn-sm btn-outline-secondary me-2" id="linkEditEmployee">Edit employee profile</a>
        <a href="/documents" class="btn btn-sm btn-primary" id="linkGenerateDocs">Generate documents</a>
      </div>
    </div>
  </div>

  <div class="col-lg-7">
    <div class="section-card mb-4">
      <div class="section-header"><h5><i class="fa-solid fa-file-signature"></i> Onboarding documents</h5></div>
      <div class="p-3" id="onboardingDocSteps">
        <p class="text-muted mb-0">Loading document sequence…</p>
      </div>
    </div>

    <div class="section-card">
      <div class="section-header"><h5><i class="fa-solid fa-clock-rotate-left"></i> Lifecycle timeline</h5></div>
      <div class="p-3" id="onboardingTimeline"><p class="text-muted mb-0">—</p></div>
    </div>
  </div>
</div>

<script>
(function () {
  const employeeId = {{employeeId}};
  let wizardState = null;

  function renderStageBadges(stageLabels) {
    const el = document.getElementById('onboardingStageBadges');
    if (!el || !stageLabels?.length) return;
    el.innerHTML = stageLabels.map((s) => {
      const cls = s.current ? 'bg-primary' : s.completed ? 'bg-success' : 'bg-light text-muted';
      return `<span class="badge ${cls}">${s.label}</span>`;
    }).join('');
  }

  function renderDocSteps(steps) {
    const el = document.getElementById('onboardingDocSteps');
    if (!steps?.length) {
      el.innerHTML = '<p class="text-muted">No onboarding documents configured for this employee type.</p>';
      return;
    }
    el.innerHTML = '<ol class="list-group list-group-numbered">' + steps.map((s) => `
      <li class="list-group-item d-flex justify-content-between align-items-center">
        <div>
          <strong>${s.label}</strong>
          <div class="small text-muted">${s.code}${s.recommended ? ' · recommended next' : ''}</div>
          ${!s.gatesValid && s.missingFields?.length ? `<div class="small text-danger">Missing: ${s.missingFields.join(', ')}</div>` : ''}
        </div>
        ${s.generated
          ? '<span class="badge bg-success">Generated</span>'
          : `<a class="btn btn-sm btn-outline-primary" href="/documents?employeeId=${employeeId}&docTypeId=${s.documentTypeId || ''}">Generate</a>`}
      </li>`).join('') + '</ol>';
  }

  function renderTimeline(events) {
    const el = document.getElementById('onboardingTimeline');
    if (!events?.length) {
      el.innerHTML = '<p class="text-muted">No lifecycle events yet.</p>';
      return;
    }
    el.innerHTML = '<ul class="list-unstyled mb-0">' + events.slice(0, 10).map((e) => `
      <li class="mb-2 small border-bottom pb-2">
        <strong>${e.action || 'event'}</strong>
        <span class="text-muted"> · ${e.fromStage || '—'} → ${e.toStage}</span>
        <div class="text-muted">${new Date(e.createdAt).toLocaleString()}</div>
      </li>`).join('') + '</ul>';
  }

  function updateReadiness(state) {
    const bar = document.getElementById('onboardingReadinessBar');
    const stage = state?.employee?.lifecycleStageLabel || '—';
    const pending = (state?.documentSteps || []).filter((s) => !s.generated).length;
    const total = (state?.documentSteps || []).length;
    bar.innerHTML = `Stage: <strong>${stage}</strong> · Documents: <strong>${total - pending}/${total}</strong> generated`;
  }

  function renderQuickActions(actions) {
    const el = document.getElementById('onboardingQuickActions');
    if (!el) return;
    if (!actions?.length) {
      el.innerHTML = '';
      return;
    }
    el.innerHTML = actions.map((a) => {
      if (a.href) {
        return `<a class="btn btn-sm btn-primary" href="${a.href}">${a.label}</a>`;
      }
      return `<button type="button" class="btn btn-sm btn-success onboarding-action-btn" data-endpoint="${a.endpoint}" data-method="${a.method || 'POST'}" title="${a.description || ''}">${a.label}</button>`;
    }).join('');
    el.querySelectorAll('.onboarding-action-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const endpoint = btn.getAttribute('data-endpoint');
        if (!endpoint) return;
        if (!confirm(btn.textContent + '?')) return;
        btn.disabled = true;
        const res = await fetch(endpoint, { method: btn.getAttribute('data-method') || 'POST' });
        const body = await res.json().catch(() => ({}));
        btn.disabled = false;
        if (!res.ok) return alert(body.error || 'Action failed');
        alert(body.message || 'Done');
        await loadWizard();
      });
    });
  }

  async function loadWizard() {
    const res = await fetch(`/api/v1/employees/${employeeId}/onboarding-wizard`);
    if (!res.ok) return alert('Failed to load onboarding workflow');
    wizardState = await res.json();

    document.getElementById('onboardingWizardSubtitle').textContent =
      `${wizardState.employee.empName} (${wizardState.employee.empId}) — ${wizardState.employee.lifecycleStageLabel}`;

    renderStageBadges(wizardState.stageLabels);
    renderDocSteps(wizardState.documentSteps);
    renderTimeline(wizardState.events);
    renderQuickActions(wizardState.suggestedActions);
    updateReadiness(wizardState);

    const stageSelect = document.getElementById('onboardingStageSelect');
    if (stageSelect && wizardState.employee?.lifecycleStage) {
      stageSelect.value = wizardState.employee.lifecycleStage;
    }

    const rec = wizardState.recommendedDocument;
    const docsLink = document.getElementById('linkGenerateDocs');
    if (docsLink) {
      docsLink.href = rec?.id
        ? `/documents?employeeId=${employeeId}&docTypeId=${rec.id}`
        : `/documents?employeeId=${employeeId}`;
    }
  }

  document.getElementById('onboardingStageForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const stage = document.getElementById('onboardingStageSelect').value;
    const res = await fetch(`/api/v1/employees/${employeeId}/onboarding-stage`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ stage }),
    });
    const body = await res.json().catch(() => ({}));
    if (!res.ok) return alert(body.error || 'Failed to update stage');
    alert('Lifecycle stage updated');
    await loadWizard();
  });

  loadWizard();
})();
</script>
