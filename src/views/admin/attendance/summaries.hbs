<nav aria-label="breadcrumb">
	<ol class="breadcrumb mb-3 bg-transparent p-0">
		<li class="breadcrumb-item"><a href="/admin">Admin</a></li>
		<li class="breadcrumb-item"><a href="/admin/attendance">Attendance</a></li>
		<li class="breadcrumb-item active" aria-current="page">Employee Summaries</li>
	</ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
	<div>
		<h2 class="mb-1">Employee Attendance Summaries</h2>
		<p class="text-muted mb-0 small">Monthly attendance overview for every employee in your organization</p>
	</div>
	<button class="btn btn-outline-secondary" onclick="loadEmployeeSummaries()" title="Refresh">
		<i class="fa-solid fa-rotate-right"></i>
	</button>
</div>

<div class="card shadow-sm mb-4">
	<div class="card-body">
		<div class="row g-3 align-items-end">
			<div class="col-md-3">
				<label class="form-label">Month</label>
				<input type="month" id="summaryMonth" class="form-control" onchange="loadEmployeeSummaries()">
			</div>
			<div class="col-md-3">
				<label class="form-label">Department</label>
				<select id="summaryDepartment" class="form-select" onchange="loadEmployeeSummaries()">
					<option value="">All departments</option>
				</select>
			</div>
			<div class="col-md-4">
				<label class="form-label">Search</label>
				<input type="text" id="summarySearch" class="form-control" placeholder="Name, employee ID, department..." oninput="filterEmployeeSummaries()">
			</div>
			<div class="col-md-2">
				<span class="badge bg-secondary w-100 py-2" id="summaryCount">0 employees</span>
			</div>
		</div>
	</div>
</div>

<div class="card shadow-sm">
	<div class="card-body p-0">
		<div class="table-responsive">
			<table class="table table-hover mb-0">
				<thead class="table-light sticky-top">
					<tr>
						<th>#</th>
						<th>Employee</th>
						<th>Department</th>
						<th class="text-center">Present</th>
						<th class="text-center">Absent</th>
						<th class="text-center">Late</th>
						<th class="text-center">Leave</th>
						<th class="text-center">Not Marked</th>
						<th class="text-center">Rate</th>
						<th class="text-center">Total Hours</th>
						<th class="text-center">Actions</th>
					</tr>
				</thead>
				<tbody id="employeeSummariesBody">
					<tr>
						<td colspan="11" class="text-center text-muted py-4">
							<i class="fa-solid fa-spinner fa-spin me-2"></i>Loading summaries...
						</td>
					</tr>
				</tbody>
			</table>
		</div>
	</div>
</div>

{{> attendance-modals }}

<!-- Employee history modal -->
<div class="modal fade" id="modalEmployeeAttendanceHistory" tabindex="-1" aria-hidden="true">
	<div class="modal-dialog modal-xl modal-dialog-scrollable">
		<div class="modal-content">
			<div class="modal-header">
				<div>
					<h5 class="modal-title mb-0" id="empHistoryTitle">Employee attendance</h5>
					<small class="text-muted" id="empHistorySubtitle"></small>
				</div>
				<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
			</div>
			<div class="modal-body">
				<div class="row g-2 mb-3" id="empHistoryStats"></div>

				<div class="card shadow-sm border-0">
					<div class="card-header text-white border-0" style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); border-radius: 10px 10px 0 0;">
						<div class="d-flex justify-content-between align-items-center">
							<h6 class="mb-0"><i class="fa-solid fa-calendar-days me-2"></i><span id="empHistoryMonthLabel">—</span></h6>
							<small class="opacity-90" id="empHistoryUpdated"></small>
						</div>
					</div>
					<div class="card-body p-3">
						<div class="admin-cal-weekdays">
							<div>Sun</div><div>Mon</div><div>Tue</div><div>Wed</div><div>Thu</div><div>Fri</div><div>Sat</div>
						</div>
						<div id="empHistoryCalendarGrid" class="admin-cal-grid">
							<div class="admin-cal-loading text-center text-muted py-4 w-100"><i class="fa-solid fa-spinner fa-spin me-2"></i>Loading calendar...</div>
						</div>
					</div>
					<div class="card-footer bg-light border-0">
						<div class="d-flex gap-3 flex-wrap small">
							<span><i class="admin-cal-dot" style="background:#22c55e;"></i> Present</span>
							<span><i class="admin-cal-dot" style="background:#ef4444;"></i> Absent</span>
							<span><i class="admin-cal-dot" style="background:#f59e0b;"></i> Late</span>
							<span><i class="admin-cal-dot" style="background:#8b5cf6;"></i> Holiday</span>
							<span><i class="admin-cal-dot" style="background:#0ea5e9;"></i> Leave</span>
							<span><i class="admin-cal-dot" style="background:#94a3b8;"></i> Week Off</span>
							<span><i class="admin-cal-dot" style="background:#6b7280;"></i> Not Marked</span>
						</div>
					</div>
				</div>
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
			</div>
		</div>
	</div>
</div>

<script src="/assets/js/attendance-status.js"></script>
<script src="/assets/js/admin-attendance.js"></script>

<style>
.admin-cal-weekdays {
	display: grid;
	grid-template-columns: repeat(7, 1fr);
	gap: 1px;
	margin-bottom: 12px;
	background: #f0f0f0;
	border-radius: 6px;
	overflow: hidden;
}
.admin-cal-weekdays > div {
	background: #6366f1;
	color: #fff;
	padding: 10px 4px;
	text-align: center;
	font-weight: 600;
	font-size: 13px;
}
.admin-cal-grid {
	display: grid;
	grid-template-columns: repeat(7, 1fr);
	gap: 8px;
	min-height: 320px;
}
.admin-cal-day {
	background: #fff;
	border: 1px solid #e5e7eb;
	border-radius: 6px;
	padding: 8px;
	min-height: 78px;
	cursor: pointer;
	transition: box-shadow 0.2s ease, transform 0.2s ease;
	display: flex;
	flex-direction: column;
}
.admin-cal-day:hover {
	box-shadow: 0 4px 6px rgba(0,0,0,0.1);
	transform: translateY(-2px);
}
.admin-cal-day.other-month { background: #f9fafb; opacity: 0.5; cursor: default; }
.admin-cal-day.other-month:hover { transform: none; box-shadow: none; }
.admin-cal-day.today { border: 2px solid #6366f1; background: #f0f4ff; }
.admin-cal-day.holiday {
	background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
	color: #fff;
	border-color: #7c3aed;
}
.admin-cal-day-date { font-weight: 600; font-size: 14px; margin-bottom: 4px; }
.admin-cal-day-times { font-size: 10px; color: #6b7280; margin-top: 2px; line-height: 1.3; }
.admin-cal-day.holiday .admin-cal-day-times { color: rgba(255,255,255,0.85); }
.admin-cal-day-status {
	font-size: 11px;
	font-weight: 500;
	padding: 3px 6px;
	border-radius: 3px;
	text-align: center;
	margin-top: auto;
}
.admin-cal-status-present { background: #d1fae5; color: #065f46; }
.admin-cal-status-absent { background: #fee2e2; color: #991b1b; }
.admin-cal-status-late { background: #fef3c7; color: #92400e; }
.admin-cal-status-leave { background: #cffafe; color: #164e63; }
.admin-cal-status-holiday { background: rgba(255,255,255,0.25); color: #fff; }
.admin-cal-status-notmarked { background: #f3f4f6; color: #374151; }
.admin-cal-holiday-name {
	font-size: 10px;
	margin-top: 2px;
	padding: 2px 4px;
	background: rgba(255,255,255,0.2);
	border-radius: 2px;
	overflow: hidden;
	white-space: nowrap;
	text-overflow: ellipsis;
}
.admin-cal-dot {
	display: inline-block;
	width: 10px;
	height: 10px;
	border-radius: 2px;
	margin-right: 4px;
	vertical-align: middle;
}
.admin-cal-loading { grid-column: 1 / -1; }
</style>
