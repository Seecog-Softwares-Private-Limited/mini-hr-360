<link href="/assets/css/company-profile.css" rel="stylesheet">
<link href="/assets/css/employee-profile.css" rel="stylesheet">

<div class="ep-page" id="employeeProfilePage" data-employee-id="{{employeeId}}">
  <div class="ep-breadcrumb mb-3">
    <a href="/employees" class="text-muted text-decoration-none"><i class="fas fa-arrow-left me-1"></i> Employees</a>
  </div>

  <div id="epLoading" class="ep-loading">
    <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
    <span class="ms-2">Loading employee profile…</span>
  </div>

  <div id="epError" class="alert alert-danger d-none" role="alert"></div>

  <div id="epContent" class="d-none">
    <div class="cp-hero ep-hero" id="epHero"></div>

    <div class="ep-stepper-wrap" id="epStepperWrap">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
        <div>
          <div class="ep-stepper-title">Employee lifecycle</div>
          <div class="ep-stepper-sub" id="epStepperSummary"></div>
        </div>
        <a href="#" class="btn btn-primary btn-sm d-none" id="epNextActionBtn">
          Complete next step <i class="fas fa-arrow-right ms-1"></i>
        </a>
      </div>
      <div class="ep-stepper" id="epStepper" aria-label="Lifecycle progress"></div>
    </div>

    <nav class="ep-tabs-nav" id="epTabsNav" aria-label="Employee profile sections"></nav>

    <div class="ep-tab-panel" id="epTabPanel" aria-live="polite"></div>
  </div>
</div>

<script src="/assets/js/employee-profile.js"></script>
